<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:icon="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:Class="SistemaCambio.App"
             RequestedThemeVariant="Dark">
    
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <!-- TEMA OSCURO -->
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#111418"/>
                    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#0d1117"/>
                    <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="#0d1117"/>
                    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#21262d"/>
                    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#0d1117"/>
                    <SolidColorBrush x:Key="BorderBrush" Color="#30363d"/>
                    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#e6edf3"/>
                    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#8b949e"/>
                    <SolidColorBrush x:Key="HoverBackgroundBrush" Color="#21262d"/>
                </ResourceDictionary>
                
                <!-- TEMA CLARO -->
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#f6f8fa"/>
                    <SolidColorBrush x:Key="SidebarBackgroundBrush" Color="#ffffff"/>
                    <SolidColorBrush x:Key="HeaderBackgroundBrush" Color="#ffffff"/>
                    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#ffffff"/>
                    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#ffffff"/>
                    <SolidColorBrush x:Key="BorderBrush" Color="#d0d7de"/>
                    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#24292f"/>
                    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#57606a"/>
                    <SolidColorBrush x:Key="HoverBackgroundBrush" Color="#f3f4f6"/>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>
    
    <Application.Styles>
        <FluentTheme />
        <icon:MaterialIconStyles />
        <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml"/>

        <!-- Sidebar Button Normal -->
        <Style Selector="Button.SidebarButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        <Style Selector="Button.SidebarButton:pointerover">
            <Setter Property="Background" Value="{DynamicResource HoverBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
        </Style>
        
        <!-- Sidebar Button Active -->
        <Style Selector="Button.SidebarButtonActive">
            <Setter Property="Background" Value="#1f6feb"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>

        <!-- TextBox Theme -->
        <Style Selector="TextBox">
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="10,8"/>
        </Style>
        <Style Selector="TextBox:focus">
            <Setter Property="BorderBrush" Value="#1f6feb"/>
        </Style>
        <!-- ReadOnly TextBox inherits theme colors -->
        <Style Selector="TextBox:disabled">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
        </Style>
        <Style Selector="TextBox[IsReadOnly=True]">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
        </Style>

        <!-- ComboBox Theme -->
        <Style Selector="ComboBox">
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="10,8"/>
        </Style>

        <!-- Button Primary (Green) -->
        <Style Selector="Button.Primary">
            <Setter Property="Background" Value="#238636"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="16,10"/>
        </Style>
        <Style Selector="Button.Primary:pointerover">
            <Setter Property="Background" Value="#2ea043"/>
        </Style>

        <!-- Button Danger (Red) -->
        <Style Selector="Button.Danger">
            <Setter Property="Background" Value="#da3633"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="16,10"/>
        </Style>
        <Style Selector="Button.Danger:pointerover">
            <Setter Property="Background" Value="#f85149"/>
        </Style>

        <!-- Button Secondary (Outline) -->
        <Style Selector="Button.Secondary">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="16,10"/>
        </Style>
        <Style Selector="Button.Secondary:pointerover">
            <Setter Property="Background" Value="{DynamicResource HoverBackgroundBrush}"/>
        </Style>

        <!-- DatePicker Theme -->
        <Style Selector="DatePicker">
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
        </Style>

        <!-- CheckBox Theme -->
        <Style Selector="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
        </Style>
        <Style Selector="CheckBox:checked">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
        </Style>

        <!-- Window Background -->
        <Style Selector="Window">
            <Setter Property="Background" Value="{DynamicResource AppBackgroundBrush}"/>
        </Style>
        
        <!-- TextBlock uses theme colors -->
        <Style Selector="TextBlock.Title">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
        </Style>
        
        <Style Selector="TextBlock.Subtitle">
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
        </Style>

        <!-- DataGrid Theme - Fixed Dark -->
        <Style Selector="DataGrid">
            <Setter Property="Background" Value="#0d1117"/>
            <Setter Property="RowBackground" Value="#0d1117"/>
            <Setter Property="BorderBrush" Value="#30363d"/>
            <Setter Property="Foreground" Value="#e6edf3"/>
        </Style>
        <Style Selector="DataGridColumnHeader">
            <Setter Property="Background" Value="#21262d"/>
            <Setter Property="Foreground" Value="#e6edf3"/>
        </Style>
        <Style Selector="DataGridRow">
            <Setter Property="Background" Value="#0d1117"/>
            <Setter Property="Foreground" Value="#e6edf3"/>
        </Style>
        <Style Selector="DataGridRow:pointerover">
            <Setter Property="Background" Value="#21262d"/>
        </Style>
        <Style Selector="DataGridCell">
            <Setter Property="Foreground" Value="#e6edf3"/>
        </Style>

        <!-- Border Card Style -->
        <Style Selector="Border.Card">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        </Style>
        
        <!-- TabItem Theme -->
        <Style Selector="TabItem">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
        </Style>
        <Style Selector="TabItem:selected">
            <Setter Property="Background" Value="{DynamicResource SidebarBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
        </Style>

    </Application.Styles>
</Application>