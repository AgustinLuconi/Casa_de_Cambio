<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:icon="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        xmlns:controls="clr-namespace:SistemaCambio.Views.Controls"
        xmlns:helpers="clr-namespace:SistemaCambio.Views.Helpers"
        x:Class="SistemaCambio.Views.NuevaCuentaWindow"
        x:CompileBindings="False"
        Title="Nueva Cuenta"
        Width="820" MinWidth="700" Height="640" MinHeight="520"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        Background="{DynamicResource AppBackgroundBrush}">

    <Grid RowDefinitions="Auto, Auto, Auto, *, Auto" Margin="20">
        
        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource CardBackgroundBrush}" 
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" 
                CornerRadius="8" Padding="14,10" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <icon:MaterialIcon Kind="BankPlus" x:Name="iconHeader" Foreground="{DynamicResource AccentBrush}" Width="22" Height="22"/>
                <TextBlock x:Name="txtTitulo" Text="Crear Nueva Cuenta" FontWeight="SemiBold" FontSize="14" 
                           Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Name -->
        <Grid Grid.Row="1" ColumnDefinitions="120, *" Margin="0,0,0,10">
            <TextBlock Text="Nombre" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}"/>
            <TextBox x:Name="txtNombre" Grid.Column="1" Watermark="Nombre de la cuenta" Text="{Binding Nombre}"/>
        </Grid>

        <!-- Type: sin selección inicial — el usuario debe elegir explícitamente -->
        <Grid Grid.Row="2" ColumnDefinitions="120, *" Margin="0,0,0,16">
            <TextBlock Text="Tipo" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}"/>
            <ComboBox x:Name="cmbTipo" Grid.Column="1" HorizontalAlignment="Stretch"
                      PlaceholderText="Seleccione un tipo..."
                      PlaceholderForeground="{DynamicResource SecondaryTextBrush}"
                      SelectedItem="{Binding TipoSeleccionado}">
                <x:String>Efectivo</x:String>
                <x:String>Banco</x:String>
                <x:String>Cliente</x:String>
                <x:String>Proveedor</x:String>
            </ComboBox>
        </Grid>

        <!-- Initial Balances: oculto hasta que el usuario elija un tipo -->
        <Border x:Name="borderSaldos" Grid.Row="3" IsVisible="{Binding BorderSaldosVisible}"
                Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                CornerRadius="8" Padding="16" Margin="0,0,0,16">
            <Grid RowDefinitions="Auto, *">
                <TextBlock Grid.Row="0" x:Name="txtSaldosTitulo" Text="Saldos Iniciales por Divisa" FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,10"/>

                <!-- Multi-moneda: para cuentas Banco/Cliente/Proveedor -->
                <DataGrid Grid.Row="1" x:Name="dgSaldosIniciales" AutoGenerateColumns="False"
                          BorderThickness="0" IsReadOnly="True"
                          HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="{DynamicResource BorderBrush}"
                          ItemsSource="{Binding SaldosIniciales}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="MONEDA" Binding="{Binding Moneda}" Width="Auto" MinWidth="90"/>
                        <DataGridTextColumn Header="NOMBRE" Binding="{Binding Nombre}" Width="*" MinWidth="160"/>
                        <DataGridTemplateColumn Header="SALDO INICIAL" Width="160">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding Saldo, Mode=TwoWay}" Background="Transparent"
                                             BorderThickness="0" Foreground="{DynamicResource PrimaryTextBrush}"
                                             Padding="5,3" TextAlignment="Right"
                                             helpers:NumericInput.Enabled="True"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <!-- Solo visible para cuentas tipo Cliente (índice 3, ver code-behind) -->
                        <DataGridTemplateColumn Header="LÍMITE ESPECÍFICO" Width="180">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding LimiteDeudaPersonalizado, Mode=TwoWay}" Background="Transparent"
                                             BorderThickness="0" Foreground="{DynamicResource PrimaryTextBrush}"
                                             Padding="5,3" TextAlignment="Right"
                                             Watermark="0 = Límite general"
                                             ToolTip.Tip="0 = hereda el límite general configurado para esta divisa"
                                             helpers:NumericInput.Enabled="True"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Mono-moneda: solo para cuentas Efectivo (caja física única denominación) -->
                <Grid x:Name="gridMonedaEfectivo" Grid.Row="1" IsVisible="False"
                      RowDefinitions="Auto, Auto, Auto" ColumnDefinitions="Auto, *">
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Moneda"
                               VerticalAlignment="Center" Margin="0,0,12,8"
                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <ComboBox Grid.Row="0" Grid.Column="1" x:Name="cmbMonedaEfectivo"
                              HorizontalAlignment="Stretch" Margin="0,0,0,8"
                              ItemsSource="{Binding MonedasEfectivo}"
                              SelectedItem="{Binding MonedaEfectivoSeleccionada}"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Saldo inicial"
                               VerticalAlignment="Center" Margin="0,0,12,8"
                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="txtSaldoEfectivo"
                             Text="{Binding SaldoEfectivoTexto}" TextAlignment="Right" Margin="0,0,0,8"
                             helpers:NumericInput.Enabled="True"/>
                    <TextBlock Grid.Row="2" Grid.ColumnSpan="2"
                               Text="Las cajas Efectivo operan con una única moneda."
                               FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"/>
                </Grid>
            </Grid>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
            <Button x:Name="btnGuardar" Content="Guardar" Classes="Primary"
                    Width="110" Height="36"
                    IsDefault="True"
                    IsEnabled="{Binding GuardarHabilitado}"
                    ToolTip.Tip="{Binding TooltipGuardar}"
                    Command="{Binding GuardarCommand}"/>
            <Button Content="Cancelar" Classes="Secondary" Width="110" Height="36"
                    Click="BtnCancelar_Click"/>
        </StackPanel>
        <controls:NotificationPanel x:Name="notificationPanel"
                                         Grid.RowSpan="5"
                                         VerticalAlignment="Top"
                                         HorizontalAlignment="Right"
                                         ZIndex="100"/>
    </Grid>
</Window>
