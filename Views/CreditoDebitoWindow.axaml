<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:icon="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        xmlns:controls="clr-namespace:SistemaCambio.Views.Controls"
        x:Class="SistemaCambio.Views.CreditoDebitoWindow"
        Title="Crédito/Débito"
        Width="750" SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="{DynamicResource AppBackgroundBrush}">

    <Grid RowDefinitions="Auto, *, Auto" Margin="16">
        
        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource CardBackgroundBrush}" 
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" 
                CornerRadius="8" Padding="14,10" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <icon:MaterialIcon Kind="SwapHorizontal" Foreground="{DynamicResource WarningBrush}" Width="22" Height="22"/>
                <TextBlock Text="Crédito / Débito entre Cuentas" FontWeight="SemiBold" FontSize="14" 
                           Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Tabs -->
        <TabControl Grid.Row="1" Background="Transparent">
            <TabControl.Styles>
                <Style Selector="TabItem">
                    <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
                    <Setter Property="Padding" Value="20,10"/>
                </Style>
                <Style Selector="TabItem:selected">
                    <Setter Property="Background" Value="{DynamicResource SidebarBackgroundBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                </Style>
            </TabControl.Styles>

            <!-- Tab 1: Crédito/Débito -->
            <TabItem Header="Credito/Debito">
                <Grid Margin="10" RowDefinitions="Auto, Auto, Auto, *">
                    
                    <!-- Note: Removed Currency textbox as per new design -->

                    <!-- Credit -->
                    <Grid Grid.Row="1" ColumnDefinitions="*, *" Margin="0,10">
                        <StackPanel Grid.Column="0" Spacing="8">
                            <TextBlock x:Name="lblCredito" Text="Crédito (Destino)" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12"/>
                            <Border Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource DangerBrush}" 
                                    BorderThickness="1" CornerRadius="8" Padding="6">
                                <ComboBox x:Name="cmbCredito" HorizontalAlignment="Stretch" 
                                          Background="Transparent" BorderThickness="0"/>
                            </Border>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="8" Margin="15,0,0,0">
                            <Grid ColumnDefinitions="Auto, *">
                                <TextBlock Text="Importe crédito" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12" VerticalAlignment="Center"/>
                                <TextBox x:Name="txtImporteCredito" Grid.Column="1" Text="0.00" TextAlignment="Right" 
                                         Margin="10,0,0,0" KeyUp="Recalcular_KeyUp" GotFocus="TextBox_GotFocus"/>
                            </Grid>
                            <Grid ColumnDefinitions="Auto, *">
                                <TextBlock Text="Cotización" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12" VerticalAlignment="Center"/>
                                <TextBox x:Name="txtCotizacion" Grid.Column="1" Text="0.00000" TextAlignment="Right" Margin="10,0,0,0"/>
                            </Grid>
                            <Grid ColumnDefinitions="Auto, *">
                                <TextBlock Text="Total" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12" VerticalAlignment="Center"/>
                                <TextBox x:Name="txtPesosCredito" Grid.Column="1" Text="0.00" TextAlignment="Right" 
                                         Margin="10,0,0,0" IsReadOnly="True"/>
                            </Grid>
                        </StackPanel>
                    </Grid>

                    <!-- Debit -->
                    <Grid Grid.Row="2" ColumnDefinitions="*, *" Margin="0,10">
                        <StackPanel Grid.Column="0" Spacing="8">
                            <TextBlock x:Name="lblDebito" Text="Débito (Origen)" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12"/>
                            <Border Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource SuccessBrush}" 
                                    BorderThickness="1" CornerRadius="8" Padding="6">
                                <ComboBox x:Name="cmbDebito" HorizontalAlignment="Stretch" 
                                          Background="Transparent" BorderThickness="0"/>
                            </Border>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="8" Margin="15,0,0,0">
                            <Grid ColumnDefinitions="Auto, *">
                                <TextBlock Text="Importe débito" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12" VerticalAlignment="Center"/>
                                <TextBox x:Name="txtImporteDebito" Grid.Column="1" Text="0.00" TextAlignment="Right" 
                                         Margin="10,0,0,0" GotFocus="TextBox_GotFocus"/>
                            </Grid>
                            <Grid ColumnDefinitions="Auto, *">
                                <TextBlock Text="Cotización" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12" VerticalAlignment="Center"/>
                                <TextBox x:Name="txtCotizacionDebito" Grid.Column="1" Text="0.00000" TextAlignment="Right" Margin="10,0,0,0"/>
                            </Grid>
                            <Grid ColumnDefinitions="Auto, *">
                                <TextBlock Text="Total" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12" VerticalAlignment="Center"/>
                                <TextBox x:Name="txtPesosDebito" Grid.Column="1" Text="0.00" TextAlignment="Right" 
                                         Margin="10,0,0,0" IsReadOnly="True"/>
                            </Grid>
                        </StackPanel>
                    </Grid>

                    <!-- Notes -->
                    <Grid Grid.Row="3" ColumnDefinitions="100, *" Margin="0,10">
                        <TextBlock Text="Observ." VerticalAlignment="Top" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,5,0,0"/>
                        <TextBox x:Name="txtObservaciones" Grid.Column="1" Height="80" AcceptsReturn="True"/>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- Tab 2: Client -->
            <TabItem Header="Cliente">
                <StackPanel Margin="20" Spacing="15">
                    <TextBlock Text="Asociar Cliente (Opcional)" FontSize="16" FontWeight="SemiBold" 
                               Foreground="{DynamicResource PrimaryTextBrush}"/>
                    
                    <Grid ColumnDefinitions="100, *">
                        <TextBlock Text="Cliente" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <ComboBox x:Name="cmbCliente" Grid.Column="1" HorizontalAlignment="Stretch"/>
                    </Grid>

                    <Grid ColumnDefinitions="100, *">
                        <TextBlock Text="Documento" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBox x:Name="txtDocumento" Grid.Column="1" IsReadOnly="True"/>
                    </Grid>

                    <Border Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" 
                            BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,20,0,0">
                        <TextBlock Text="El cliente seleccionado se asociará a la operación de crédito/débito." 
                                   Foreground="{DynamicResource SecondaryTextBrush}" TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </TabItem>
        </TabControl>

        <!-- Error Panel -->
        <Border x:Name="borderError" IsVisible="False"
                Background="#DC262620" BorderBrush="{DynamicResource DangerBrush}"
                BorderThickness="1" CornerRadius="8" Padding="12,8" Margin="0,8,0,0">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <icon:MaterialIcon Kind="AlertCircle" Foreground="{DynamicResource DangerBrush}"
                                  Width="16" Height="16" VerticalAlignment="Center"/>
                <TextBlock x:Name="txtErrorServidor" Text="" TextWrapping="Wrap"
                           Foreground="{DynamicResource DangerBrush}" FontSize="12"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Footer -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Aceptar" Background="{DynamicResource AccentBrush}" Foreground="White" 
                    Width="110" Height="36" HorizontalContentAlignment="Center" CornerRadius="8" 
                    Cursor="Hand" Click="BtnAceptar_Click"/>
            <Button Content="Cancelar" Classes="Secondary" Width="110" Height="36" 
                    HorizontalContentAlignment="Center" Click="BtnCancelar_Click"/>
        </StackPanel>
        <controls:NotificationPanel x:Name="notificationPanel"
                                         Grid.RowSpan="3"
                                         VerticalAlignment="Top"
                                         HorizontalAlignment="Right"
                                         ZIndex="100"/>
    </Grid>
</Window>
