<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:icon="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        xmlns:controls="clr-namespace:SistemaCambio.Views.Controls"
        xmlns:helpers="clr-namespace:SistemaCambio.Views.Helpers"
        x:Class="SistemaCambio.Views.CreditoDebitoWindow"
        Title="Crédito/Débito"
        Width="580" Height="640"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="{DynamicResource AppBackgroundBrush}">

    <Grid RowDefinitions="*, Auto, Auto" Margin="12">

        <!-- ─────────── Formulario ─────────── -->
        <Grid Grid.Row="0" Margin="16,14,16,12"
              ColumnDefinitions="110, *"
              RowDefinitions="Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto">

            <!-- Fila 0: Moneda -->
            <TextBlock Grid.Row="0" Grid.Column="0"
                       Text="Moneda" VerticalAlignment="Center"
                       Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,10"/>
            <Grid Grid.Row="0" Grid.Column="1" ColumnDefinitions="95, *" Margin="0,0,0,10">
                <ComboBox x:Name="cmbMoneda" Grid.Column="0"
                          HorizontalAlignment="Stretch"
                          SelectionChanged="CmbMoneda_SelectionChanged"/>
                <TextBox x:Name="txtMonedaDescripcion" Grid.Column="1" Margin="8,0,0,0"
                         Foreground="{DynamicResource PrimaryTextBrush}"
                         TextChanged="TxtMoneda_TextChanged"
                         LostFocus="TxtMoneda_LostFocus"/>
            </Grid>

            <!-- Separador arriba de Crédito -->
            <Border Grid.Row="1" Grid.ColumnSpan="2"
                    Height="1" Background="{DynamicResource BorderBrush}"
                    Margin="0,2,0,10"/>

            <!-- Fila 2: Crédito (cuenta ROJA) -->
            <TextBlock Grid.Row="2" Grid.Column="0"
                       Text="Crédito" VerticalAlignment="Center"
                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,10"/>
            <ComboBox x:Name="cmbCredito" Grid.Row="2" Grid.Column="1"
                      HorizontalAlignment="Stretch" Margin="0,0,0,10"
                      FontWeight="SemiBold"
                      Background="#CC0000" Foreground="White" BorderBrush="#990000"/>

            <!-- Fila 3: Importe Crédito + sub-bloque (Cotización / Pesos) -->
            <TextBlock Grid.Row="3" Grid.Column="0"
                       Text="Importe&#x0a;crédito" VerticalAlignment="Center"
                       Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,10"/>
            <Grid Grid.Row="3" Grid.Column="1" ColumnDefinitions="*, 230" Margin="0,0,0,10">
                <TextBox x:Name="txtImporteCredito" Grid.Column="0"
                         Text="0.00" TextAlignment="Right"
                         FontSize="20" FontWeight="Bold"
                         helpers:NumericInput.Enabled="True"
                         KeyUp="RecalcularCredito_KeyUp" GotFocus="TextBox_GotFocus" LostFocus="TextBox_LostFocus"/>
                <StackPanel Grid.Column="1" Spacing="4" Margin="12,0,0,0">
                    <Grid ColumnDefinitions="80, *">
                        <TextBlock Text="Cotización" VerticalAlignment="Center"
                                   Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12"/>
                        <TextBox x:Name="txtCotizacionCredito" Grid.Column="1"
                                 Text="0.00000" TextAlignment="Right"
                                 Background="{DynamicResource SidebarBackgroundBrush}"
                                 Foreground="{DynamicResource SecondaryTextBrush}"
                                 helpers:NumericInput.Enabled="True"
                                 KeyUp="RecalcularCredito_KeyUp" GotFocus="TextBox_GotFocus" LostFocus="TextBox_LostFocus"/>
                    </Grid>
                    <Grid ColumnDefinitions="80, *">
                        <TextBlock Text="Pesos" VerticalAlignment="Center"
                                   Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12"/>
                        <TextBox x:Name="txtPesosCredito" Grid.Column="1"
                                 Text="0.00" TextAlignment="Right" IsReadOnly="True" IsTabStop="False"
                                 Background="{DynamicResource SidebarBackgroundBrush}"
                                 Foreground="{DynamicResource SecondaryTextBrush}"/>
                    </Grid>
                </StackPanel>
            </Grid>

            <!-- Separador entre Crédito y Débito -->
            <Border Grid.Row="4" Grid.ColumnSpan="2"
                    Height="1" Background="{DynamicResource BorderBrush}"
                    Margin="0,2,0,10"/>

            <!-- Fila 5: Débito (cuenta VERDE) -->
            <TextBlock Grid.Row="5" Grid.Column="0"
                       Text="Débito" VerticalAlignment="Center"
                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,10"/>
            <ComboBox x:Name="cmbDebito" Grid.Row="5" Grid.Column="1"
                      HorizontalAlignment="Stretch" Margin="0,0,0,10"
                      FontWeight="SemiBold"
                      Background="#008800" Foreground="White" BorderBrush="#005500"/>

            <!-- Fila 6: Importe Débito + sub-bloque (Cotización / Pesos) -->
            <TextBlock Grid.Row="6" Grid.Column="0"
                       Text="Importe&#x0a;débito" VerticalAlignment="Center"
                       Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,10"/>
            <Grid Grid.Row="6" Grid.Column="1" ColumnDefinitions="*, 230" Margin="0,0,0,10">
                <TextBox x:Name="txtImporteDebito" Grid.Column="0"
                         Text="0.00" TextAlignment="Right"
                         FontSize="20" FontWeight="Bold"
                         helpers:NumericInput.Enabled="True"
                         KeyUp="RecalcularDebito_KeyUp" GotFocus="TextBox_GotFocus" LostFocus="TextBox_LostFocus"/>
                <StackPanel Grid.Column="1" Spacing="4" Margin="12,0,0,0">
                    <Grid ColumnDefinitions="80, *">
                        <TextBlock Text="Cotización" VerticalAlignment="Center"
                                   Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12"/>
                        <TextBox x:Name="txtCotizacionDebito" Grid.Column="1"
                                 Text="0.00000" TextAlignment="Right"
                                 Background="{DynamicResource SidebarBackgroundBrush}"
                                 Foreground="{DynamicResource SecondaryTextBrush}"
                                 helpers:NumericInput.Enabled="True"
                                 KeyUp="RecalcularDebito_KeyUp" GotFocus="TextBox_GotFocus" LostFocus="TextBox_LostFocus"/>
                    </Grid>
                    <Grid ColumnDefinitions="80, *">
                        <TextBlock Text="Pesos" VerticalAlignment="Center"
                                   Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12"/>
                        <TextBox x:Name="txtPesosDebito" Grid.Column="1"
                                 Text="0.00" TextAlignment="Right" IsReadOnly="True" IsTabStop="False"
                                 Background="{DynamicResource SidebarBackgroundBrush}"
                                 Foreground="{DynamicResource SecondaryTextBrush}"/>
                    </Grid>
                </StackPanel>
            </Grid>

            <!-- Separador antes de Observ -->
            <Border Grid.Row="7" Grid.ColumnSpan="2"
                    Height="1" Background="{DynamicResource BorderBrush}"
                    Margin="0,2,0,10"/>

            <!-- Fila 8: Observaciones -->
            <TextBlock Grid.Row="8" Grid.Column="0"
                       Text="Observ." VerticalAlignment="Center"
                       Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,10"/>
            <TextBox x:Name="txtObservaciones" Grid.Row="8" Grid.Column="1"
                     Height="32" Margin="0,0,0,10"/>

        </Grid>

        <!-- ─────────── Error panel ─────────── -->
        <Border x:Name="borderError" Grid.Row="1" IsVisible="False"
                Background="#DC262620" BorderBrush="{DynamicResource DangerBrush}"
                BorderThickness="1" CornerRadius="8" Padding="12,8" Margin="0,8,0,0">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <icon:MaterialIcon Kind="AlertCircle" Foreground="{DynamicResource DangerBrush}"
                                   Width="16" Height="16" VerticalAlignment="Center"/>
                <TextBlock x:Name="txtErrorServidor" Text="" TextWrapping="Wrap"
                           Foreground="{DynamicResource DangerBrush}" FontSize="12"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- ─────────── Footer: Aceptar / Cancelar ─────────── -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="10"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="btnAceptar" Content="Aceptar" Classes="Primary"
                    Width="110" Height="36"
                    Click="BtnAceptar_Click"/>
            <Button Content="Cancelar" Classes="Secondary"
                    Width="110" Height="36"
                    Click="BtnCancelar_Click"/>
        </StackPanel>

        <controls:NotificationPanel x:Name="notificationPanel"
                                    Grid.RowSpan="3"
                                    VerticalAlignment="Top"
                                    HorizontalAlignment="Right"
                                    ZIndex="100"/>
    </Grid>
</Window>
