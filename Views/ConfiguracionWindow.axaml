<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:icon="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        xmlns:controls="clr-namespace:SistemaCambio.Views.Controls"
        xmlns:helpers="clr-namespace:SistemaCambio.Views.Helpers"
        x:Class="SistemaCambio.Views.ConfiguracionWindow"
        x:CompileBindings="False"
        Title="Configuración"
        Width="800" Height="600"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        Background="{DynamicResource AppBackgroundBrush}">

    <Grid RowDefinitions="Auto, *, Auto" Margin="16">
        
        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource CardBackgroundBrush}" 
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" 
                CornerRadius="8" Padding="14,10" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <icon:MaterialIcon Kind="Cog" Foreground="{DynamicResource SecondaryTextBrush}" Width="22" Height="22"/>
                <TextBlock Text="Configuración del Sistema" FontWeight="SemiBold" FontSize="14" 
                           Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Tabs -->
        <TabControl Grid.Row="1" Background="Transparent">
            <TabControl.Styles>
                <Style Selector="TabItem">
                    <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
                    <Setter Property="Padding" Value="20,10"/>
                </Style>
                <Style Selector="TabItem:selected">
                    <Setter Property="Background" Value="{DynamicResource SidebarBackgroundBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                </Style>
            </TabControl.Styles>

            <!-- Tab: General -->
            <TabItem Header="General">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="20" Spacing="20">
                    
                    <!-- Theme -->
                    <Border Background="{DynamicResource SidebarBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" 
                            BorderThickness="1" CornerRadius="8" Padding="20">
                        <Grid ColumnDefinitions="*, Auto">
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Tema de la Aplicación" FontWeight="SemiBold" 
                                           Foreground="{DynamicResource PrimaryTextBrush}" FontSize="14"/>
                                <TextBlock Text="Alterna entre tema oscuro y claro" 
                                           Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,5,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="15" VerticalAlignment="Center">
                                <TextBlock Text="Oscuro" Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center"/>
                                <ToggleSwitch x:Name="toggleTema" IsChecked="True" OnContent="" OffContent="" IsCheckedChanged="ToggleTema_Changed"/>
                                <TextBlock Text="Claro" Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- System Info -->
                    <Border Background="{DynamicResource SidebarBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" 
                            BorderThickness="1" CornerRadius="8" Padding="20">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Información del Sistema" FontWeight="SemiBold" 
                                       Foreground="{DynamicResource PrimaryTextBrush}" FontSize="14"/>
                            <Grid ColumnDefinitions="150, *" RowDefinitions="Auto, Auto, Auto, Auto" Margin="0,10,0,0">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Versión:" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="1.0.0" Foreground="{DynamicResource PrimaryTextBrush}"/>
                                
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Base de datos:" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,5,0,0"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="PostgreSQL" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,5,0,0"/>
                                
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Framework:" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,5,0,0"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="Avalonia UI 11.0" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,5,0,0"/>
                                
                                <TextBlock Grid.Row="3" Grid.Column="0" Text=".NET:" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,5,0,0"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text=".NET 8.0" Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,5,0,0"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Límites de Deuda Generales por Divisa -->
                    <Border Background="{DynamicResource SidebarBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="20">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Límites de Deuda Generales por Divisa" FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" FontSize="14"/>
                            <TextBlock Text="Se aplican a cuentas de tipo Cliente sin límite específico para esa divisa. Dejá un campo en 0 para quitar el límite de esa divisa."
                                       Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12"/>

                            <!-- Opción global: sin límite para todas las divisas -->
                            <Border Background="{DynamicResource AppBackgroundBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                    CornerRadius="6" Padding="12,10" Margin="0,4,0,8">
                                <Grid ColumnDefinitions="*, Auto">
                                    <StackPanel Grid.Column="0" Spacing="2">
                                        <TextBlock Text="Sin límite general" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource PrimaryTextBrush}" FontSize="13"/>
                                        <TextBlock Text="Los clientes pueden tomar deuda sin restricción en todas las divisas. Los límites individuales son ignorados mientras esta opción esté activa."
                                                   Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="toggleSinLimite" Grid.Column="1"
                                                  OnContent="" OffContent=""
                                                  VerticalAlignment="Center" Margin="16,0,0,0"
                                                  IsCheckedChanged="ToggleSinLimite_Changed"/>
                                </Grid>
                            </Border>

                            <!-- Una fila por moneda activa: código + nombre + límite editable -->
                            <ItemsControl x:Name="icLimitesDivisa" Margin="0,5,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnDefinitions="70, *, 180" Margin="0,3">
                                            <TextBlock Text="{Binding Codigo}" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                                       VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Nombre}"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                       VerticalAlignment="Center" Margin="8,0"/>
                                            <TextBox Grid.Column="2" Text="{Binding LimiteTexto, Mode=TwoWay}"
                                                     Watermark="0 (sin límite)" TextAlignment="Right"
                                                     helpers:NumericInput.Enabled="True"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Button Content="Guardar Límites" Background="{DynamicResource AccentBrush}"
                                    Foreground="White" CornerRadius="6" Cursor="Hand"
                                    HorizontalAlignment="Right" Padding="14,8"
                                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                    Click="BtnGuardarLimitesDivisa_Click"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Tab: Monedas -->
            <TabItem Header="Monedas">
                <Grid Margin="10" RowDefinitions="Auto, *">
                    <StackPanel Grid.Row="0" Spacing="15" Margin="0,10,0,15">
                        
                        <!-- New Currency Form -->
                        <Border Background="{DynamicResource SidebarBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" 
                                BorderThickness="1" CornerRadius="8" Padding="16">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Agregar Nueva Moneda" FontWeight="SemiBold" 
                                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                                <Grid ColumnDefinitions="Auto, 100, Auto, *, Auto" RowDefinitions="Auto">
                                    <TextBlock Grid.Column="0" Text="Código:" VerticalAlignment="Center" 
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,10,0"/>
                                    <TextBox x:Name="txtNuevoCodigo" Grid.Column="1" Watermark="Ej: BRL" MaxLength="10"/>
                                    
                                    <TextBlock Grid.Column="2" Text="Nombre:" VerticalAlignment="Center" 
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="20,0,10,0"/>
                                    <TextBox x:Name="txtNuevoNombre" Grid.Column="3" Watermark="Ej: Real Brasileño" MaxLength="100"/>
                                    
                                    <Button Grid.Column="4" Content="Agregar Moneda" Background="{DynamicResource AccentBrush}"
                                            Foreground="White" CornerRadius="6" Margin="20,0,0,0" Cursor="Hand"
                                            HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                            Click="BtnNuevaMoneda_Click"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Action Buttons -->
                        <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                            <Button Content="Refrescar" Classes="Secondary" Click="BtnRefrescarMonedas_Click"/>
                            <Button Content="Guardar Editados" Background="{DynamicResource AccentBrush}"
                                    Foreground="White" CornerRadius="6" Cursor="Hand"
                                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                    IsDefault="True"
                                    Click="BtnGuardarCambios_Click"/>
                        </StackPanel>
                    </StackPanel>
                    
                    <DataGrid Grid.Row="1" x:Name="dgMonedas" AutoGenerateColumns="False"
                              BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}" IsReadOnly="True"
                              HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="{DynamicResource BorderBrush}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                            <DataGridTemplateColumn Header="CÓDIGO" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding Codigo, Mode=TwoWay}" Background="Transparent" 
                                                 BorderThickness="0" Foreground="{DynamicResource PrimaryTextBrush}" Padding="5,3"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="NOMBRE" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding Nombre, Mode=TwoWay}" Background="Transparent" 
                                                 BorderThickness="0" Foreground="{DynamicResource PrimaryTextBrush}" Padding="5,3"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="ACTIVA" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding Activa, Mode=TwoWay}" HorizontalAlignment="Center" Margin="0,2"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="" Width="60">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Classes="Danger" Background="Transparent" Foreground="{DynamicResource DangerBrush}" 
                                                Padding="4" Margin="2" HorizontalAlignment="Center" Cursor="Hand"
                                                ToolTip.Tip="Eliminar moneda" Click="BtnEliminarMoneda_Click">
                                            <icon:MaterialIcon Kind="Delete" Width="18" Height="18"/>
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Tab: Cotizaciones -->
            <TabItem Header="Cotizaciones del Día">
                <Grid Margin="10" RowDefinitions="Auto, Auto, *">
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10" Margin="0,10,0,15">
                        <TextBlock Text="Fecha:" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <DatePicker x:Name="dpFechaCotizacion" Width="200"/>
                        <Button Content="Cargar" Background="{DynamicResource AccentBrush}" Foreground="White"
                                CornerRadius="6" Cursor="Hand"
                                HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                Click="BtnCargarCotizaciones_Click"/>
                    </StackPanel>
                    
                    <Border Grid.Row="1" Background="{DynamicResource SidebarBackgroundBrush}" 
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" 
                            CornerRadius="8" Padding="16" Margin="0,0,0,15">
                        <Grid ColumnDefinitions="100, 150, 100, 150, Auto">
                            <TextBlock Grid.Column="0" Text="Moneda:" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}"/>
                            <ComboBox x:Name="cmbMonedaCotiz" Grid.Column="1" HorizontalAlignment="Stretch"/>
                            <TextBlock Grid.Column="2" Text="Compra:" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}" Margin="15,0,0,0"/>
                            <TextBox x:Name="txtCotizCompra" Grid.Column="3" Text="0.00000" TextAlignment="Right"
                                     helpers:NumericInput.Enabled="True"/>
                            <Button Grid.Column="4" Content="Guardar" Background="{DynamicResource SuccessBrush}"
                                    Foreground="White" CornerRadius="6" Margin="15,0,0,0" Cursor="Hand"
                                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                    IsDefault="True"
                                    Click="BtnGuardarCotizacion_Click"/>
                        </Grid>
                    </Border>
                    
                    <DataGrid Grid.Row="2" x:Name="dgCotizaciones" AutoGenerateColumns="False"
                              BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="MONEDA" Binding="{Binding MonedaCodigo}" Width="100"/>
                            <DataGridTextColumn Header="FECHA" Binding="{Binding Fecha, StringFormat='{}{0:dd/MM/yyyy}'}" Width="120"/>
                            <DataGridTextColumn Header="COMPRA" Binding="{Binding CotizacionCompra, StringFormat='{}{0:N5}'}" Width="150"/>
                            <DataGridTextColumn Header="VENTA" Binding="{Binding CotizacionVenta, StringFormat='{}{0:N5}'}" Width="150"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Footer -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cerrar" Classes="Secondary" Width="100" Height="36"
                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                    Click="BtnCerrar_Click"/>
        </StackPanel>
        <controls:NotificationPanel x:Name="notificationPanel"
                                         Grid.RowSpan="3"
                                         VerticalAlignment="Top"
                                         HorizontalAlignment="Right"
                                         ZIndex="100"/>
    </Grid>
</Window>
