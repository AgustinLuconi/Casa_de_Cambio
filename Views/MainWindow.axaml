<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SistemaCambio.ViewModels"
        xmlns:icon="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        xmlns:controls="clr-namespace:SistemaCambio.Views.Controls"
        xmlns:sp="clr-namespace:ScottPlot.Avalonia;assembly=ScottPlot.Avalonia"
        x:Class="SistemaCambio.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Treasury ERP"
        Background="{DynamicResource AppBackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        Width="1400" Height="900">

    <Window.KeyBindings>
        <KeyBinding Gesture="F1" Command="{Binding AbrirDashboardCommand}"/>
        <KeyBinding Gesture="F2" Command="{Binding AbrirCuentasCommand}"/>
        <KeyBinding Gesture="F3" Command="{Binding AbrirCompraCommand}"/>
        <KeyBinding Gesture="F4" Command="{Binding AbrirVentaCommand}"/>
        <KeyBinding Gesture="F5" Command="{Binding AbrirCreditoDebitoCommand}"/>
        <KeyBinding Gesture="F6" Command="{Binding AbrirArqueoCommand}"/>
        <KeyBinding Gesture="F7" Command="{Binding AbrirMovimientosCommand}"/>
    </Window.KeyBindings>

    <Grid RowDefinitions="Auto, *, Auto">
        
        <!-- ═══════════════════════ HEADER ═══════════════════════ -->
        <Border Grid.Row="0" Background="{DynamicResource HeaderBackgroundBrush}" 
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="20,12">
            <Grid ColumnDefinitions="Auto, *, Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <!-- Title/Icon removed as requested -->
                </StackPanel>

                <!-- Toolbar -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                    <Button Classes="toolbar-btn" Command="{Binding AbrirDashboardCommand}" ToolTip.Tip="Dashboard (F1)">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <TextBlock Text="F1" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" FontSize="11"/>
                            <TextBlock Text="Dashboard" FontSize="12"/>
                        </StackPanel>
                    </Button>
                    <Button Classes="toolbar-btn" Command="{Binding AbrirCuentasCommand}" ToolTip.Tip="Cuentas (F2)">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <TextBlock Text="F2" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" FontSize="11"/>
                            <TextBlock Text="Cuentas" FontSize="12"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="btnToolbarCompra" Classes="toolbar-btn" Command="{Binding AbrirCompraCommand}" ToolTip.Tip="Compra (F3)">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <TextBlock Text="F3" FontWeight="Bold" Foreground="{DynamicResource SuccessBrush}" FontSize="11"/>
                            <TextBlock Text="Compra" FontSize="12"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="btnToolbarVenta" Classes="toolbar-btn" Command="{Binding AbrirVentaCommand}" ToolTip.Tip="Venta (F4)">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <TextBlock Text="F4" FontWeight="Bold" Foreground="{DynamicResource DangerBrush}" FontSize="11"/>
                            <TextBlock Text="Venta" FontSize="12"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="btnToolbarCreditoDebito" Classes="toolbar-btn" Command="{Binding AbrirCreditoDebitoCommand}" ToolTip.Tip="Crédito/Débito (F5)">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <TextBlock Text="F5" FontWeight="Bold" Foreground="{DynamicResource WarningBrush}" FontSize="11"/>
                            <TextBlock Text="Créd/Déb" FontSize="12"/>
                        </StackPanel>
                    </Button>
                    <Button Classes="toolbar-btn" Command="{Binding AbrirArqueoCommand}" ToolTip.Tip="Arqueo (F6)">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <TextBlock Text="F6" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" FontSize="11"/>
                            <TextBlock Text="Arqueo" FontSize="12"/>
                        </StackPanel>
                    </Button>
                    <Button Classes="toolbar-btn" Command="{Binding AbrirMovimientosCommand}" ToolTip.Tip="Movimientos (F7)">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <TextBlock Text="F7" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" FontSize="11"/>
                            <TextBlock Text="Movimientos" FontSize="12"/>
                        </StackPanel>
                    </Button>
                    <Button Classes="toolbar-btn" Click="BtnCierreCaja_Click" ToolTip.Tip="Cierre de Caja (F8)">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <TextBlock Text="F8" FontWeight="Bold" Foreground="{DynamicResource WarningBrush}" FontSize="11"/>
                            <TextBlock Text="Cierre" FontSize="12"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Mi Cuenta + Historial -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <Button Classes="toolbar-btn" Click="BtnMiCuenta_Click" ToolTip.Tip="Mi Cuenta">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <icon:MaterialIcon Kind="AccountCircle" Width="16" Height="16"
                                               Foreground="{DynamicResource AccentBrush}"/>
                            <TextBlock Text="Mi Cuenta" FontSize="12"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="btnHistorial" Classes="toolbar-btn"
                            Click="BtnHistorial_Click" ToolTip.Tip="Historial de notificaciones">
                        <Panel>
                            <icon:MaterialIcon Kind="Bell" Width="16" Height="16"
                                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                            <Border x:Name="badgeHistorial"
                                    Background="{DynamicResource DangerBrush}"
                                    CornerRadius="6" Width="14" Height="14"
                                    HorizontalAlignment="Right" VerticalAlignment="Top"
                                    Margin="0,-4,-4,0" IsVisible="False">
                                <TextBlock x:Name="txtBadgeCount" Text="0" FontSize="9"
                                           FontWeight="Bold" Foreground="White"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Panel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════ CONTENT ═══════════════════════ -->
        <Grid Grid.Row="1" ColumnDefinitions="230, *">
            
            <!-- SIDEBAR -->
            <Border Grid.Column="0" Background="{DynamicResource SidebarBackgroundBrush}" 
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
                <ScrollViewer>
                    <StackPanel Margin="10">
                        <TextBlock Text="PRINCIPAL" FontSize="10" FontWeight="Bold" 
                                   Foreground="{DynamicResource SecondaryTextBrush}" Margin="14,15,0,8"/>
                        
                        <Button x:Name="btnDashboard" Classes="SidebarButton" Click="BtnDashboard_Click">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <icon:MaterialIcon Kind="ViewDashboard" Width="18" Height="18"/>
                                <TextBlock Text="Dashboard" VerticalAlignment="Center" FontSize="13"/>
                            </StackPanel>
                        </Button>
                        
                        <Button x:Name="btnCuentas" Classes="SidebarButtonActive" Click="BtnCuentas_Click">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <icon:MaterialIcon Kind="Bank" Width="18" Height="18"/>
                                <TextBlock Text="Cuentas" VerticalAlignment="Center" FontSize="13"/>
                            </StackPanel>
                        </Button>

                        <TextBlock Text="OPERACIONES" FontSize="10" FontWeight="Bold" 
                                   Foreground="{DynamicResource SecondaryTextBrush}" Margin="14,25,0,8"/>
                        
                        <Button x:Name="btnCompra" Classes="SidebarButton" Click="BtnCompra_Click">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <icon:MaterialIcon Kind="CartArrowDown" Width="18" Height="18"/>
                                <TextBlock Text="Compra (F3)" VerticalAlignment="Center" FontSize="13"/>
                            </StackPanel>
                        </Button>
                        
                        <Button x:Name="btnVenta" Classes="SidebarButton" Click="BtnVenta_Click">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <icon:MaterialIcon Kind="CartArrowUp" Width="18" Height="18"/>
                                <TextBlock Text="Venta (F4)" VerticalAlignment="Center" FontSize="13"/>
                            </StackPanel>
                        </Button>
                        
                        <Button x:Name="btnCreditoDebito" Classes="SidebarButton" Click="BtnCreditoDebito_Click">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <icon:MaterialIcon Kind="SwapHorizontal" Width="18" Height="18"/>
                                <TextBlock Text="Crédito/Débito (F5)" VerticalAlignment="Center" FontSize="13"/>
                            </StackPanel>
                        </Button>

                        <TextBlock Text="AUDITORÍA" FontSize="10" FontWeight="Bold" 
                                   Foreground="{DynamicResource SecondaryTextBrush}" Margin="14,25,0,8"/>
                        
                        <Button x:Name="btnArqueo" Classes="SidebarButton" Click="BtnArqueo_Click">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <icon:MaterialIcon Kind="Calculator" Width="18" Height="18"/>
                                <TextBlock Text="Arqueo (F6)" VerticalAlignment="Center" FontSize="13"/>
                            </StackPanel>
                        </Button>
                        
                        <Button x:Name="btnMovimientos" Classes="SidebarButton" Click="BtnMovimientos_Click">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <icon:MaterialIcon Kind="History" Width="18" Height="18"/>
                                <TextBlock Text="Movimientos (F7)" VerticalAlignment="Center" FontSize="13"/>
                            </StackPanel>
                        </Button>
                        
                        <Button x:Name="btnCierreCaja" Classes="SidebarButton" Click="BtnCierreCaja_Click">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <icon:MaterialIcon Kind="CashRegister" Width="18" Height="18"/>
                                <TextBlock Text="Cierre de Caja (F8)" VerticalAlignment="Center" FontSize="13"/>
                            </StackPanel>
                        </Button>

                        <TextBlock Text="SISTEMA" FontSize="10" FontWeight="Bold" 
                                   Foreground="{DynamicResource SecondaryTextBrush}" Margin="14,25,0,8"/>
                        
                        <Button Classes="SidebarButton" Click="BtnReportes_Click">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <icon:MaterialIcon Kind="ChartLine" Width="18" Height="18"/>
                                <TextBlock Text="Reportes" VerticalAlignment="Center" FontSize="13"/>
                            </StackPanel>
                        </Button>
                        
                        <Button Classes="SidebarButton" Click="BtnConfiguracion_Click">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <icon:MaterialIcon Kind="Cog" Width="18" Height="18"/>
                                <TextBlock Text="Configuración" VerticalAlignment="Center" FontSize="13"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- MAIN AREA -->
            <Grid Grid.Column="1" Margin="24,20" RowDefinitions="Auto, Auto, *">
                
                <!-- Title Bar -->
                <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,20">
                    <TextBlock x:Name="txtMainTitle" Text="Cuentas Overview" FontSize="22" FontWeight="Bold" 
                               Foreground="{DynamicResource PrimaryTextBrush}"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
                        <Button Background="{DynamicResource AccentBrush}" Foreground="White" Padding="14,8" 
                                CornerRadius="8" Click="BtnNuevaCuenta_Click" Cursor="Hand">
                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <icon:MaterialIcon Kind="Plus" Width="16" Height="16" VerticalAlignment="Center"/>
                                <TextBlock Text="Nueva Cuenta" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Classes="Secondary" Padding="14,8" Click="BtnExportar_Click">
                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <icon:MaterialIcon Kind="Download" Width="16" Height="16" VerticalAlignment="Center"/>
                                <TextBlock Text="Exportar" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- DASHBOARD PANEL -->
                <ScrollViewer x:Name="dashboardPanel" Grid.Row="1" Grid.RowSpan="2" IsVisible="False" Margin="0,0,0,0" Padding="0,0,16,0">
                    <StackPanel Spacing="24" Margin="0,0,0,40">
                        <!-- Stat Cards -->
                        <UniformGrid Columns="4" Rows="1" Margin="0,0,0,0">
                            <!-- Card 1 -->
                            <Border Background="#1AFFFFFF" BorderBrush="#33FFFFFF" 
                                    BorderThickness="1" CornerRadius="16" Padding="24" Margin="0,0,16,0">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <icon:MaterialIcon Kind="Bank" Width="20" Height="20" Foreground="{DynamicResource AccentBrush}"/>
                                        <TextBlock Text="Total Cuentas" FontSize="14" Foreground="#B0B5C9"/>
                                    </StackPanel>
                                    <TextBlock x:Name="txtTotalCuentas" Text="0" FontSize="36" FontWeight="Bold" 
                                               Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,12,0,0"/>
                                </StackPanel>
                            </Border>
                            <!-- Card 2 -->
                            <Border Background="#1AFFFFFF" BorderBrush="#33FFFFFF" 
                                    BorderThickness="1" CornerRadius="16" Padding="24" Margin="0,0,16,0">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <icon:MaterialIcon Kind="SwapHorizontal" Width="20" Height="20" Foreground="{DynamicResource WarningBrush}"/>
                                        <TextBlock Text="Operaciones Hoy" FontSize="14" Foreground="#B0B5C9"/>
                                    </StackPanel>
                                    <TextBlock x:Name="txtOperacionesHoy" Text="0" FontSize="36" FontWeight="Bold" 
                                               Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,12,0,0"/>
                                </StackPanel>
                            </Border>
                            <!-- Card 3 -->
                            <Border Background="#13a4ec33" BorderBrush="#13a4ec80" 
                                    BorderThickness="1" CornerRadius="16" Padding="24" Margin="0,0,16,0">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <icon:MaterialIcon Kind="CurrencyUsd" Width="20" Height="20" Foreground="#13a4ec"/>
                                        <TextBlock Text="Saldo Total (USD)" FontSize="14" Foreground="#B0B5C9"/>
                                    </StackPanel>
                                    <TextBlock x:Name="txtSaldoUSD" Text="$0.00" FontSize="32" FontWeight="Bold" 
                                               Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,12,0,0"/>
                                </StackPanel>
                            </Border>
                            <!-- Card 4 -->
                            <Border Background="#4ade8033" BorderBrush="#4ade8080" 
                                    BorderThickness="1" CornerRadius="16" Padding="24" Margin="0">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <icon:MaterialIcon Kind="CurrencyEur" Width="20" Height="20" Foreground="#4ade80"/>
                                        <TextBlock Text="Saldo Total (EUR/ARS)" FontSize="14" Foreground="#B0B5C9"/>
                                    </StackPanel>
                                    <TextBlock x:Name="txtSaldoARS" Text="$0.00" FontSize="32" FontWeight="Bold" 
                                               Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,12,0,0"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                        
                        <!-- Métricas del día -->
                        <UniformGrid Columns="4" Rows="1">
                            <Border Background="#1a2332" BorderBrush="#233c4a" BorderThickness="1"
                                    CornerRadius="8" Padding="20,14" Margin="0,0,16,0">
                                <StackPanel>
                                    <TextBlock Text="OPERACIONES HOY" FontSize="11" Foreground="#94a3b8" Margin="0,0,0,6"/>
                                    <TextBlock Text="{Binding TotalOperacionesHoy}" FontSize="28" FontWeight="Bold" Foreground="White"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#1a2332" BorderBrush="#233c4a" BorderThickness="1"
                                    CornerRadius="8" Padding="20,14" Margin="0,0,16,0">
                                <StackPanel>
                                    <TextBlock Text="COMPRAS HOY" FontSize="11" Foreground="#94a3b8" Margin="0,0,0,6"/>
                                    <TextBlock Text="{Binding TotalComprasHoy}" FontSize="28" FontWeight="Bold" Foreground="White"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#1a2332" BorderBrush="#233c4a" BorderThickness="1"
                                    CornerRadius="8" Padding="20,14" Margin="0,0,16,0">
                                <StackPanel>
                                    <TextBlock Text="VENTAS HOY" FontSize="11" Foreground="#94a3b8" Margin="0,0,0,6"/>
                                    <TextBlock Text="{Binding TotalVentasHoy}" FontSize="28" FontWeight="Bold" Foreground="White"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#1a2332" BorderBrush="#233c4a" BorderThickness="1"
                                    CornerRadius="8" Padding="20,14" Margin="0">
                                <StackPanel>
                                    <TextBlock Text="VOLUMEN NETO ARS" FontSize="11" Foreground="#94a3b8" Margin="0,0,0,6"/>
                                    <TextBlock Text="{Binding VolumenNetoARS, StringFormat='$ {0:N0}'}"
                                               FontSize="22" FontWeight="Bold" Foreground="White"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <!-- Middle Charts -->
                        <Grid ColumnDefinitions="2*, 1*">
                            <!-- Left Chart (Balance Evolution) -->
                            <Border Grid.Column="0" Margin="0,0,24,0" Background="#0Cffffff" BorderBrush="#22ffffff" BorderThickness="1" CornerRadius="16" Padding="24">
                                <StackPanel>
                                    <TextBlock Text="Evolución de Saldos" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}"/>
                                    <sp:AvaPlot x:Name="pltBalanceEvolution" Height="300" Margin="0,16,0,0"/>
                                </StackPanel>
                            </Border>
                            
                            <!-- Right Chart (Currency Distribution) -->
                            <Border Grid.Column="1" Background="#0Cffffff" BorderBrush="#22ffffff" BorderThickness="1" CornerRadius="16" Padding="24">
                                <StackPanel>
                                    <TextBlock Text="Distribución Monedas" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}"/>
                                    <sp:AvaPlot x:Name="pltCurrencyDistribution" Height="300" Margin="0,16,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Operaciones Diarias (30 días) -->
                        <Border Background="#0Cffffff" BorderBrush="#22ffffff" BorderThickness="1" CornerRadius="16" Padding="24">
                            <StackPanel>
                                <TextBlock Text="Operaciones Diarias (últimos 30 días)" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}"/>
                                <sp:AvaPlot x:Name="pltOperacionesDiarias" Height="280" Margin="0,16,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Comparativo Mensual + Distribución por Moneda -->
                        <Grid ColumnDefinitions="1*, 1*">
                            <Border Grid.Column="0" Margin="0,0,12,0" Background="#0Cffffff" BorderBrush="#22ffffff" BorderThickness="1" CornerRadius="16" Padding="24">
                                <StackPanel>
                                    <TextBlock Text="Comparativo Mensual (6 meses)" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}"/>
                                    <sp:AvaPlot x:Name="pltComparativoMensual" Height="280" Margin="0,16,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Margin="12,0,0,0" Background="#0Cffffff" BorderBrush="#22ffffff" BorderThickness="1" CornerRadius="16" Padding="24">
                                <StackPanel>
                                    <TextBlock Text="Distribución por Moneda (30 días)" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryTextBrush}"/>
                                    <sp:AvaPlot x:Name="pltDistribucionMonedas" Height="280" Margin="0,16,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Cotizaciones del Día -->
                        <Border Background="#0Cffffff" BorderBrush="#22ffffff"
                                BorderThickness="1" CornerRadius="16" Padding="24">
                            <StackPanel>
                                <TextBlock Text="Cotizaciones de Hoy" FontSize="18" FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12"/>
                                <DataGrid ItemsSource="{Binding CotizacionesHoy}"
                                          AutoGenerateColumns="False" IsReadOnly="True"
                                          BorderThickness="0" Background="Transparent"
                                          GridLinesVisibility="Horizontal"
                                          HorizontalGridLinesBrush="{DynamicResource BorderBrush}"
                                          HeadersVisibility="Column">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="MONEDA" Binding="{Binding CodigoMoneda}" Width="120" FontWeight="SemiBold"/>
                                        <DataGridTextColumn Header="COMPRA" Binding="{Binding CotizacionCompra, StringFormat='{}{0:N4}'}" Width="*"/>
                                        <DataGridTextColumn Header="VENTA"  Binding="{Binding CotizacionVenta,  StringFormat='{}{0:N4}'}" Width="*"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Border>

                        <!-- Bottom: Recent Transactions -->
                        <Border Background="#0Cffffff" BorderBrush="#22ffffff" 
                                BorderThickness="1" CornerRadius="16" Padding="24">
                            <StackPanel>
                                <TextBlock Text="Últimas Operaciones" FontSize="18" FontWeight="SemiBold" 
                                           Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,16"/>
                                <DataGrid x:Name="dgUltimasOperaciones" AutoGenerateColumns="True" 
                                          IsReadOnly="True" MinHeight="250"
                                          BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}"
                                          GridLinesVisibility="Horizontal"
                                          HorizontalGridLinesBrush="{DynamicResource BorderBrush}"
                                          HeadersVisibility="Column"
                                          Background="Transparent"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- ACCOUNTS PANEL -->
                <StackPanel x:Name="cuentasPanel" Grid.Row="1" Margin="0,0,0,16">
                    <Border Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" 
                            BorderThickness="1" CornerRadius="10" Padding="16">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBox Watermark="Buscar por ID o Nombre..." Width="250"
                                     Text="{Binding TextoBusqueda}"/>
                            <ComboBox Width="150"
                                      ItemsSource="{Binding TiposFiltro}"
                                      SelectedItem="{Binding FiltroTipoSeleccionado}"/>
                            <ComboBox Width="150"
                                      ItemsSource="{Binding MonedasFiltro}"
                                      SelectedItem="{Binding FiltroMonedaSeleccionada}"/>
                            <Button Background="{DynamicResource HoverBackgroundBrush}" BorderThickness="1"
                                    BorderBrush="{DynamicResource BorderBrush}" CornerRadius="6" Padding="8"
                                    Command="{Binding LimpiarFiltrosCommand}"
                                    ToolTip.Tip="Limpiar filtros">
                                <icon:MaterialIcon Kind="Refresh" Width="16" Height="16"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                            </Button>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Accounts DataGrid -->
                <DataGrid x:Name="dgCuentas" Grid.Row="2" ItemsSource="{Binding Cuentas}" AutoGenerateColumns="False"
                          BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="{DynamicResource BorderBrush}"
                          HeadersVisibility="Column"
                          IsReadOnly="True">
                    
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                        <DataGridTextColumn Header="CUENTA" Binding="{Binding Nombre}" Width="*" FontWeight="SemiBold"/>
                        <DataGridTextColumn Header="TIPO" Binding="{Binding Tipo}" Width="110"/>
                        <DataGridTextColumn Header="SALDOS" Binding="{Binding SaldosResumen}" Width="320"/>
                        <DataGridTemplateColumn Header="" Width="150">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel x:CompileBindings="False" Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <!-- Ver Detalles: con etiqueta visible -->
                                        <Button Background="#1A16A34A" BorderBrush="#3316A34A" BorderThickness="1"
                                                CornerRadius="6" Padding="8,4" Margin="0"
                                                Cursor="Hand" ToolTip.Tip="Ver todos los saldos de esta cuenta"
                                                Command="{Binding #cuentasPanel.DataContext.VerDetalleCuentaCommand}"
                                                CommandParameter="{Binding}">
                                            <StackPanel Orientation="Horizontal" Spacing="5">
                                                <icon:MaterialIcon Kind="Eye" Width="13" Height="13" Foreground="{DynamicResource SuccessBrush}" VerticalAlignment="Center"/>
                                                <TextBlock Text="Detalles" FontSize="11" Foreground="{DynamicResource SuccessBrush}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <!-- Editar -->
                                        <Button Classes="Secondary" Background="Transparent" Padding="4" Margin="0"
                                                Cursor="Hand" ToolTip.Tip="Editar Cuenta"
                                                Command="{Binding #cuentasPanel.DataContext.EditarCuentaCommand}"
                                                CommandParameter="{Binding}">
                                            <icon:MaterialIcon Kind="Pencil" Width="15" Height="15" Foreground="{DynamicResource AccentBrush}"/>
                                        </Button>
                                        <!-- Eliminar -->
                                        <Button Classes="Danger" Background="Transparent" Padding="4" Margin="0"
                                                Cursor="Hand" ToolTip.Tip="Eliminar Cuenta"
                                                Command="{Binding #cuentasPanel.DataContext.EliminarCuentaCommand}"
                                                CommandParameter="{Binding}">
                                            <icon:MaterialIcon Kind="Delete" Width="15" Height="15" Foreground="{DynamicResource DangerBrush}"/>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Grid>

        <!-- ═══════════════════════ FOOTER ═══════════════════════ -->
        <Border Grid.Row="2" Background="{DynamicResource SidebarBackgroundBrush}" 
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="20,10">
            <Grid ColumnDefinitions="Auto, *, Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="20">
                    <TextBlock Text="Sistema v1.0.0" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <TextBlock Text="Server: Local" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <Border x:Name="borderDiaCerrado"
                            IsVisible="False"
                            Background="#DC262620"
                            BorderBrush="{DynamicResource DangerBrush}"
                            BorderThickness="1" CornerRadius="4" Padding="8,3">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <icon:MaterialIcon Kind="Lock" Width="12" Height="12"
                                               Foreground="{DynamicResource DangerBrush}"/>
                            <TextBlock Text="DÍA CERRADO" FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource DangerBrush}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="5" HorizontalAlignment="Center">
                    <TextBlock Text="Cuentas:" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <TextBlock Text="{Binding CuentasCount}" FontSize="11" FontWeight="Bold" 
                               Foreground="{DynamicResource PrimaryTextBrush}"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="24">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="TOTAL DÉBITO" FontSize="10" Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding TotalDebito, StringFormat='{}{0:N2}'}" FontSize="14" FontWeight="Bold" 
                                   Foreground="{DynamicResource DangerBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="TOTAL CRÉDITO" FontSize="10" Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding TotalCredito, StringFormat='{}{0:N2}'}" FontSize="14" FontWeight="Bold" 
                                   Foreground="{DynamicResource SuccessBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Border Background="{DynamicResource HoverBackgroundBrush}" CornerRadius="6" Padding="12,6">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="POSICIÓN NETA" FontSize="10" Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding PosicionNeta, StringFormat='{}{0:N2}'}" FontSize="16" FontWeight="Bold" 
                                       Foreground="{DynamicResource AccentBrush}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Notification Panel -->
        <controls:NotificationPanel x:Name="notificationPanel"
                                     Grid.Row="0"
                                     Grid.RowSpan="3"
                                     VerticalAlignment="Top"
                                     HorizontalAlignment="Right"/>

        <!-- Panel historial de notificaciones (overlay) -->
        <Border x:Name="panelHistorial"
                IsVisible="False"
                Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1" CornerRadius="10"
                Width="380" MaxHeight="520"
                Grid.Row="0" Grid.RowSpan="3"
                VerticalAlignment="Top" HorizontalAlignment="Right"
                Margin="0,50,16,0"
                BoxShadow="0 8 24 0 #AA000000"
                ZIndex="100">
            <Grid RowDefinitions="Auto, *, Auto" Margin="16">
                <!-- Header -->
                <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="0,0,0,12">
                    <TextBlock Text="Historial de Notificaciones"
                               FontWeight="SemiBold" FontSize="14"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Content="Limpiar"
                            Classes="secondary-btn"
                            FontSize="11" Padding="8,4"
                            Click="BtnLimpiarHistorial_Click"/>
                </Grid>

                <!-- Lista -->
                <ScrollViewer Grid.Row="1" MaxHeight="400">
                    <ItemsControl x:Name="icHistorial">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:CompileBindings="False">
                                <Border BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="0,0,0,1"
                                        Padding="0,8">
                                    <Grid ColumnDefinitions="8, *">
                                        <Border Grid.Column="0"
                                                Width="4" CornerRadius="2"
                                                Background="{Binding ColorIndicador}"
                                                VerticalAlignment="Stretch"
                                                Margin="0,2,8,2"/>
                                        <StackPanel Grid.Column="1" Spacing="2">
                                            <Grid ColumnDefinitions="*, Auto">
                                                <TextBlock Text="{Binding Title}"
                                                           FontWeight="SemiBold" FontSize="12"
                                                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding Timestamp, StringFormat='{}{0:HH:mm}'}"
                                                           FontSize="10"
                                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                                           VerticalAlignment="Center"/>
                                            </Grid>
                                            <TextBlock Text="{Binding Message}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                       IsVisible="{Binding TieneMessage}"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Sin notificaciones -->
                <TextBlock Grid.Row="2"
                           x:Name="txtSinNotificaciones"
                           Text="Sin notificaciones recientes"
                           FontSize="12"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,12,0,4"
                           IsVisible="False"/>
            </Grid>
        </Border>
    </Grid>
</Window>