<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:icon="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        xmlns:controls="clr-namespace:SistemaCambio.Views.Controls"
        x:Class="SistemaCambio.Views.DetalleMovimientosWindow"
        x:CompileBindings="False"
        Title="Movimientos y Operaciones"
        Width="1440" MinWidth="1100" Height="780" MinHeight="580"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        Background="{DynamicResource AppBackgroundBrush}">

    <Grid RowDefinitions="Auto, *, Auto" Margin="16">

        <controls:NotificationPanel x:Name="notificationPanel"
                                    Grid.RowSpan="3"
                                    VerticalAlignment="Top"
                                    HorizontalAlignment="Right"
                                    ZIndex="100"/>

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                CornerRadius="8" Padding="14,10" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <icon:MaterialIcon Kind="History" Foreground="{DynamicResource AccentBrush}" Width="22" Height="22"/>
                <TextBlock Text="Movimientos y Operaciones" FontWeight="SemiBold" FontSize="14"
                           Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Tabs -->
        <TabControl Grid.Row="1" Background="Transparent">
            <TabControl.Styles>
                <Style Selector="TabItem">
                    <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
                    <Setter Property="Padding" Value="20,10"/>
                </Style>
                <Style Selector="TabItem:selected">
                    <Setter Property="Background" Value="{DynamicResource SidebarBackgroundBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                </Style>
            </TabControl.Styles>

            <!-- Tab 1: Movimientos -->
            <TabItem Header="Movimientos por Cuenta">
                <Grid Margin="10" RowDefinitions="Auto, *, Auto">

                    <!-- Filters -->
                    <Border Grid.Row="0" Background="{DynamicResource SidebarBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            CornerRadius="8" Padding="16" Margin="0,10,0,16">
                        <Grid RowDefinitions="Auto, Auto, Auto" ColumnDefinitions="Auto, *, 24, Auto, *">

                            <!-- Row 1: Cuenta / Cuenta Externa -->
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Cuenta" VerticalAlignment="Center"
                                       Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,10,8"/>
                            <ComboBox x:Name="cmbCuenta" Grid.Row="0" Grid.Column="1"
                                      HorizontalAlignment="Stretch" Margin="0,0,0,8"
                                      ItemsSource="{Binding CuentasFiltro}"
                                      SelectedItem="{Binding CuentaSeleccionada}"/>

                            <TextBlock Grid.Row="0" Grid.Column="3" Text="Cuenta Externa" VerticalAlignment="Center"
                                       Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,10,8"/>
                            <ComboBox x:Name="cmbCuentaExterna" Grid.Row="0" Grid.Column="4"
                                      HorizontalAlignment="Stretch" Margin="0,0,0,8"
                                      ItemsSource="{Binding CuentasExternaFiltro}"
                                      SelectedItem="{Binding CuentaExternaSeleccionada}"/>

                            <!-- Row 2: Rango de fechas -->
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Desde" VerticalAlignment="Center"
                                       Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,10,8"/>
                            <DatePicker x:Name="dpDesde" Grid.Row="1" Grid.Column="1"
                                        HorizontalAlignment="Stretch" Margin="0,0,0,8"
                                        SelectedDate="{Binding FechaDesde}"
                                        IsEnabled="{Binding HistoricosActivado}"/>

                            <TextBlock Grid.Row="1" Grid.Column="3" Text="Hasta" VerticalAlignment="Center"
                                       Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,10,8"/>
                            <DatePicker x:Name="dpHasta" Grid.Row="1" Grid.Column="4"
                                        HorizontalAlignment="Stretch" Margin="0,0,0,8"
                                        SelectedDate="{Binding FechaHasta}"
                                        IsEnabled="{Binding HistoricosActivado}"/>

                            <!-- Row 3: Moneda / CheckBox históricos -->
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Moneda" VerticalAlignment="Center"
                                       Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,10,0"/>
                            <ComboBox x:Name="cmbMoneda" Grid.Row="2" Grid.Column="1" HorizontalAlignment="Stretch"
                                      ItemsSource="{Binding MonedasFiltro}"
                                      SelectedItem="{Binding MonedaSeleccionada}"/>

                            <CheckBox x:Name="chkHistoricos" Grid.Row="2" Grid.Column="3" Grid.ColumnSpan="2"
                                      Content="Buscar movimientos históricos" VerticalAlignment="Center"
                                      IsChecked="{Binding HistoricosActivado}"/>
                        </Grid>
                    </Border>

                    <!-- DataGrid movimientos -->
                    <DataGrid Grid.Row="1" x:Name="dgMovimientos" AutoGenerateColumns="False"
                              BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="{DynamicResource BorderBrush}"
                              HeadersVisibility="Column"
                              HorizontalScrollBarVisibility="Disabled"
                              IsReadOnly="True"
                              ItemsSource="{Binding Movimientos}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="FECHA"
                                                Binding="{Binding Fecha, StringFormat='{}{0:dd/MM/yyyy HH:mm}'}"
                                                Width="Auto" MinWidth="120"/>
                            <DataGridTextColumn Header="CÓDIGO" Binding="{Binding CodigoOperacion}"
                                                Width="Auto" MinWidth="90"/>
                            <DataGridTextColumn Header="OPERACIÓN" Binding="{Binding TipoOperacion}"
                                                Width="*" MinWidth="80"/>
                            <DataGridTextColumn Header="CUENTA" Binding="{Binding CuentaNombre}"
                                                Width="*" MinWidth="100"/>
                            <DataGridTextColumn Header="MON." Binding="{Binding Moneda}"
                                                Width="Auto" MinWidth="48"/>
                            <DataGridTextColumn Header="DÉBITO"
                                                Binding="{Binding Debito, StringFormat='{}{0:N2}'}"
                                                Width="Auto" MinWidth="90"/>
                            <DataGridTextColumn Header="CRÉDITO"
                                                Binding="{Binding Credito, StringFormat='{}{0:N2}'}"
                                                Width="Auto" MinWidth="90"/>
                            <DataGridTemplateColumn Header="OBSERVACIONES" Width="2*" MinWidth="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate x:CompileBindings="False">
                                        <TextBlock Text="{Binding Observaciones}"
                                                   TextWrapping="Wrap"
                                                   Padding="8,4"
                                                   VerticalAlignment="Center"
                                                   ToolTip.Tip="{Binding Observaciones}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Footer del tab -->
                    <Grid Grid.Row="2" ColumnDefinitions="*, Auto, Auto, Auto" Margin="0,12,0,0">
                        <TextBlock Grid.Column="0" x:Name="txtResultados" Text="{Binding TextoResultados}"
                                   Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="Exportar PDF" Classes="Secondary" Height="40"
                                Margin="0,0,10,0"
                                HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                Click="BtnExportarMovimientosPdf_Click"/>
                        <Button Grid.Column="2" Content="Exportar Excel" Classes="Secondary" Height="40"
                                Margin="0,0,10,0"
                                HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                Click="BtnExportarMovimientosCsv_Click"/>
                        <Button Grid.Column="3" Classes="Primary"
                                Width="110" Height="40"
                                IsDefault="True"
                                Command="{Binding BuscarCommand}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <icon:MaterialIcon Kind="Magnify" Width="16" Height="16" VerticalAlignment="Center"/>
                                <TextBlock Text="Buscar" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- Tab 2: Operaciones (con anulación) -->
            <TabItem Header="Operaciones">
                <Grid Margin="10" RowDefinitions="Auto, *">

                    <!-- Filtros -->
                    <Border Grid.Row="0" Background="{DynamicResource SidebarBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            CornerRadius="8" Padding="16" Margin="0,10,0,16">
                        <StackPanel Spacing="10">
                            <StackPanel Orientation="Horizontal" Spacing="15">
                                <TextBlock Text="Desde:" VerticalAlignment="Center"
                                           Foreground="{DynamicResource SecondaryTextBrush}"/>
                                <DatePicker x:Name="dpDesdeOp" SelectedDate="{Binding FechaDesdeOp}"/>
                                <TextBlock Text="Hasta:" VerticalAlignment="Center"
                                           Foreground="{DynamicResource SecondaryTextBrush}"/>
                                <DatePicker x:Name="dpHastaOp" SelectedDate="{Binding FechaHastaOp}"/>
                                <Button Content="Generar" Background="{DynamicResource AccentBrush}" Foreground="White"
                                        CornerRadius="6" Cursor="Hand"
                                        HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                        Command="{Binding GenerarCommand}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="15">
                                <TextBlock Text="Tipo:" VerticalAlignment="Center"
                                           Foreground="{DynamicResource SecondaryTextBrush}"/>
                                <ComboBox Width="150" ItemsSource="{Binding TiposOperacionFiltro}"
                                          SelectedItem="{Binding TipoOperacionSeleccionado}"/>
                                <TextBlock Text="Cuenta:" VerticalAlignment="Center"
                                           Foreground="{DynamicResource SecondaryTextBrush}"/>
                                <ComboBox Width="170" ItemsSource="{Binding CuentasOpFiltro}"
                                          SelectedItem="{Binding CuentaOpSeleccionada}"/>
                                <TextBlock Text="Estado:" VerticalAlignment="Center"
                                           Foreground="{DynamicResource SecondaryTextBrush}"/>
                                <ComboBox Width="130" ItemsSource="{Binding EstadosFiltro}"
                                          SelectedItem="{Binding EstadoSeleccionado}"/>
                                <TextBlock Text="Código:" VerticalAlignment="Center"
                                           Foreground="{DynamicResource SecondaryTextBrush}"/>
                                <TextBox Width="120" Watermark="ej. 00023" Text="{Binding CodigoOperacionBusqueda}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- DataGrid operaciones -->
                    <DataGrid Grid.Row="1" x:Name="dgOperaciones" AutoGenerateColumns="False"
                              BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}" IsReadOnly="True"
                              ItemsSource="{Binding Operaciones}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="CÓDIGO" Binding="{Binding CodigoOperacion}" Width="Auto" MinWidth="100"/>
                            <DataGridTextColumn Header="FECHA"
                                                Binding="{Binding Fecha, StringFormat='{}{0:dd/MM/yyyy HH:mm}'}"
                                                Width="Auto" MinWidth="158"/>
                            <DataGridTextColumn Header="TIPO" Binding="{Binding TipoOperacion}" Width="Auto" MinWidth="130"/>
                            <DataGridTextColumn Header="MONTO ORIGEN"
                                                Binding="{Binding MontoTotalOrigen, StringFormat='{}{0:N2}'}"
                                                Width="Auto" MinWidth="135"/>
                            <DataGridTextColumn Header="MONTO DESTINO"
                                                Binding="{Binding MontoTotalDestino, StringFormat='{}{0:N2}'}"
                                                Width="Auto" MinWidth="135"/>
                            <DataGridTextColumn Header="OBSERVACIONES" Binding="{Binding Observaciones}" Width="*" MinWidth="150"/>
                            <DataGridTextColumn Header="ESTADO" Binding="{Binding EstadoDisplay}" Width="Auto" MinWidth="105"/>
                            <DataGridTemplateColumn Header="" Width="90">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Anular"
                                                Tag="{Binding}"
                                                IsEnabled="{Binding PuedeAnular}"
                                                IsVisible="{Binding PuedeAnular}"
                                                FontSize="11"
                                                Padding="6,3"
                                                Background="{DynamicResource DangerBrush}"
                                                Foreground="White"
                                                CornerRadius="4"
                                                Click="BtnAnular_Click"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Footer -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cerrar" Classes="Secondary" Width="100" Height="36"
                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                    Click="BtnCancelar_Click"/>
        </StackPanel>
    </Grid>
</Window>
