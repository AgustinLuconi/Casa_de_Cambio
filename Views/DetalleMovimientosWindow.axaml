<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:icon="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        x:Class="SistemaCambio.Views.DetalleMovimientosWindow"
        x:CompileBindings="False"
        Title="Detalle Movimientos de una Cuenta"
        Width="900" Height="650"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        Background="{DynamicResource AppBackgroundBrush}">

    <Grid RowDefinitions="Auto, Auto, *, Auto" Margin="16">
        
        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource CardBackgroundBrush}" 
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" 
                CornerRadius="8" Padding="14,10" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <icon:MaterialIcon Kind="History" Foreground="{DynamicResource AccentBrush}" Width="22" Height="22"/>
                <TextBlock Text="Detalle Movimientos de una Cuenta" FontWeight="SemiBold" FontSize="14" 
                           Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Filters -->
        <Border Grid.Row="1" Background="{DynamicResource CardBackgroundBrush}" 
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" 
                CornerRadius="8" Padding="16" Margin="0,0,0,16">
            <Grid RowDefinitions="Auto, Auto, Auto" ColumnDefinitions="100, *, 100, *">
                
                <!-- Row 1 -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Cuenta" VerticalAlignment="Center" 
                           Foreground="{DynamicResource SecondaryTextBrush}"/>
                <ComboBox x:Name="cmbCuenta" Grid.Row="0" Grid.Column="1" HorizontalAlignment="Stretch" Margin="0,0,20,10"/>
                
                <TextBlock Grid.Row="0" Grid.Column="2" Text="Cuenta Externa" VerticalAlignment="Center" 
                           Foreground="{DynamicResource SecondaryTextBrush}"/>
                <ComboBox x:Name="cmbCuentaExterna" Grid.Row="0" Grid.Column="3" HorizontalAlignment="Stretch" Margin="0,0,0,10"/>
                
                <!-- Row 2 -->
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Desde" VerticalAlignment="Center" 
                           Foreground="{DynamicResource SecondaryTextBrush}"/>
                <DatePicker x:Name="dpDesde" Grid.Row="1" Grid.Column="1" HorizontalAlignment="Stretch" Margin="0,0,20,10"/>
                
                <TextBlock Grid.Row="1" Grid.Column="2" Text="Hasta" VerticalAlignment="Center" 
                           Foreground="{DynamicResource SecondaryTextBrush}"/>
                <DatePicker x:Name="dpHasta" Grid.Row="1" Grid.Column="3" HorizontalAlignment="Stretch" Margin="0,0,0,10"/>
                
                <!-- Row 3 -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Moneda" VerticalAlignment="Center" 
                           Foreground="{DynamicResource SecondaryTextBrush}"/>
                <ComboBox x:Name="cmbMoneda" Grid.Row="2" Grid.Column="1" HorizontalAlignment="Stretch" Margin="0,0,20,0">
                    <ComboBoxItem Content="Todas" Tag=""/>
                </ComboBox>
                
                <CheckBox x:Name="chkHistoricos" Grid.Row="2" Grid.Column="2" Grid.ColumnSpan="2" 
                          Content="Buscar movimientos históricos" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- DataGrid -->
        <DataGrid Grid.Row="2" x:Name="dgMovimientos" AutoGenerateColumns="False" 
                  BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="{DynamicResource BorderBrush}"
                  HeadersVisibility="Column"
                  IsReadOnly="True">

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                <DataGridTextColumn Header="FECHA" Binding="{Binding Fecha, StringFormat='{}{0:dd/MM/yyyy HH:mm}'}" Width="140"/>
                <DataGridTextColumn Header="OPERACIÓN" Binding="{Binding TipoOperacion}" Width="120"/>
                <DataGridTextColumn Header="CUENTA" Binding="{Binding CuentaNombre}" Width="*"/>
                <DataGridTextColumn Header="MONEDA" Binding="{Binding Moneda}" Width="100"/>
                <DataGridTextColumn Header="DÉBITO" Binding="{Binding Debito, StringFormat='{}{0:N2}'}" Width="120"/>
                <DataGridTextColumn Header="CRÉDITO" Binding="{Binding Credito, StringFormat='{}{0:N2}'}" Width="120"/>
                <DataGridTextColumn Header="OBSERVACIONES" Binding="{Binding Observaciones}" Width="200"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Footer -->
        <Grid Grid.Row="3" ColumnDefinitions="*, Auto, Auto" Margin="0,16,0,0">
            <TextBlock Grid.Column="0" x:Name="txtResultados" Text="0 movimientos encontrados" 
                       Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center"/>
            <Button Grid.Column="1" Background="{DynamicResource AccentBrush}" Foreground="White" 
                    Width="110" Height="36" HorizontalContentAlignment="Center" CornerRadius="8" 
                    Cursor="Hand" Click="BtnBuscar_Click">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <icon:MaterialIcon Kind="Magnify" Width="16" Height="16"/>
                    <TextBlock Text="Buscar"/>
                </StackPanel>
            </Button>
            <Button Grid.Column="2" Content="Cancelar" Classes="Secondary" Width="100" Height="36" 
                    HorizontalContentAlignment="Center" Margin="10,0,0,0" Click="BtnCancelar_Click"/>
        </Grid>
    </Grid>
</Window>
