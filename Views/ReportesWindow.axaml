<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:icon="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        x:Class="SistemaCambio.Views.ReportesWindow"
        x:CompileBindings="False"
        Title="Reportes"
        Width="950" Height="700"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        Background="{DynamicResource AppBackgroundBrush}">

    <Grid RowDefinitions="Auto, *, Auto" Margin="16">
        
        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource CardBackgroundBrush}" 
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" 
                CornerRadius="8" Padding="14,10" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <icon:MaterialIcon Kind="ChartLine" Foreground="{DynamicResource AccentBrush}" Width="22" Height="22"/>
                <TextBlock Text="Reportes" FontWeight="SemiBold" FontSize="14" 
                           Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Tabs -->
        <TabControl Grid.Row="1" Background="Transparent">
            <TabControl.Styles>
                <Style Selector="TabItem">
                    <Setter Property="Background" Value="{DynamicResource CardBackgroundBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
                    <Setter Property="Padding" Value="20,10"/>
                </Style>
                <Style Selector="TabItem:selected">
                    <Setter Property="Background" Value="{DynamicResource SidebarBackgroundBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
                </Style>
            </TabControl.Styles>

            <!-- Tab: Operations by Date -->
            <TabItem Header="Operaciones por Fecha">
                <Grid Margin="10" RowDefinitions="Auto, *">
                    <Border Grid.Row="0" Background="{DynamicResource SidebarBackgroundBrush}" 
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" 
                            CornerRadius="8" Padding="16" Margin="0,10,0,16">
                        <StackPanel Orientation="Horizontal" Spacing="15">
                            <TextBlock Text="Desde:" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}"/>
                            <DatePicker x:Name="dpDesdeOp" Width="150"/>
                            <TextBlock Text="Hasta:" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}"/>
                            <DatePicker x:Name="dpHastaOp" Width="150"/>
                            <Button Content="Generar" Background="{DynamicResource AccentBrush}" Foreground="White"
                                    CornerRadius="6" Cursor="Hand"
                                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                    Click="BtnGenerarOperaciones_Click"/>
                            <Button Content="Exportar CSV" Classes="Secondary" Click="BtnExportarOperaciones_Click"/>
                        </StackPanel>
                    </Border>
                    
                    <DataGrid Grid.Row="1" x:Name="dgOperaciones" AutoGenerateColumns="False"
                              BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                            <DataGridTextColumn Header="FECHA" Binding="{Binding Fecha, StringFormat='{}{0:dd/MM/yyyy HH:mm}'}" Width="150"/>
                            <DataGridTextColumn Header="TIPO" Binding="{Binding TipoOperacion}" Width="120"/>
                            <DataGridTextColumn Header="MONTO ORIGEN" Binding="{Binding MontoTotalOrigen, StringFormat='{}{0:N2}'}" Width="130"/>
                            <DataGridTextColumn Header="MONTO DESTINO" Binding="{Binding MontoTotalDestino, StringFormat='{}{0:N2}'}" Width="130"/>
                            <DataGridTextColumn Header="COTIZACIÓN" Binding="{Binding CotizacionAplicada, StringFormat='{}{0:N5}'}" Width="120"/>
                            <DataGridTextColumn Header="OBSERVACIONES" Binding="{Binding Observaciones}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Tab: Balances by Account -->
            <TabItem Header="Saldos por Cuenta">
                <Grid Margin="10" RowDefinitions="Auto, *">
                    <Border Grid.Row="0" Background="{DynamicResource SidebarBackgroundBrush}" 
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" 
                            CornerRadius="8" Padding="16" Margin="0,10,0,16">
                        <StackPanel Orientation="Horizontal" Spacing="15">
                            <TextBlock Text="Tipo:" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}"/>
                            <ComboBox x:Name="cmbTipoSaldos" Width="150" SelectedIndex="0">
                                <ComboBoxItem>Todos</ComboBoxItem>
                                <ComboBoxItem>Caja</ComboBoxItem>
                                <ComboBoxItem>Banco</ComboBoxItem>
                                <ComboBoxItem>Cliente</ComboBoxItem>
                            </ComboBox>
                            <Button Content="Generar" Background="{DynamicResource AccentBrush}" Foreground="White"
                                    CornerRadius="6" Cursor="Hand"
                                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                                    Click="BtnGenerarSaldos_Click"/>
                            <Button Content="Exportar CSV" Classes="Secondary" Click="BtnExportarSaldos_Click"/>
                        </StackPanel>
                    </Border>
                    
                    <DataGrid Grid.Row="1" x:Name="dgSaldos" AutoGenerateColumns="False"
                              BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                            <DataGridTextColumn Header="CUENTA" Binding="{Binding Nombre}" Width="*"/>
                            <DataGridTextColumn Header="TIPO" Binding="{Binding Tipo}" Width="100"/>
                            <DataGridTextColumn Header="MONEDA" Binding="{Binding Moneda}" Width="100"/>
                            <DataGridTextColumn Header="SALDO" Binding="{Binding Saldo, StringFormat='{}{0:N2}'}" Width="150"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Footer -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cerrar" Classes="Secondary" Width="100" Height="36" 
                    HorizontalContentAlignment="Center" Click="BtnCerrar_Click"/>
        </StackPanel>
    </Grid>
</Window>
