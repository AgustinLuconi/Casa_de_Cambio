<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:icon="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        x:Class="SistemaCambio.Views.ReportesWindow"
        x:CompileBindings="False"
        Title="Reportes"
        Width="950" Height="700"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        Background="#161b22">

    <Grid RowDefinitions="Auto, *, Auto" Margin="15">
        
        <!-- Header -->
        <Border Grid.Row="0" Background="#21262d" BorderBrush="#30363d" BorderThickness="1" CornerRadius="6" Padding="12,8" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <icon:MaterialIcon Kind="ChartLine" Foreground="#a371f7" Width="24" Height="24"/>
                <TextBlock Text="Reportes" FontWeight="Bold" FontSize="14" Foreground="#e6edf3" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Tabs -->
        <TabControl Grid.Row="1" Background="Transparent">
            <TabControl.Styles>
                <Style Selector="TabItem">
                    <Setter Property="Background" Value="#21262d"/>
                    <Setter Property="Foreground" Value="#8b949e"/>
                    <Setter Property="Padding" Value="20,10"/>
                </Style>
                <Style Selector="TabItem:selected">
                    <Setter Property="Background" Value="#0d1117"/>
                    <Setter Property="Foreground" Value="White"/>
                </Style>
            </TabControl.Styles>

            <!-- Tab: Operaciones por Fecha -->
            <TabItem Header="Operaciones por Fecha">
                <Grid Margin="10" RowDefinitions="Auto, *">
                    <!-- Filtros -->
                    <Border Grid.Row="0" Background="#0d1117" CornerRadius="6" Padding="15" Margin="0,10,0,15">
                        <StackPanel Orientation="Horizontal" Spacing="15">
                            <TextBlock Text="Desde:" VerticalAlignment="Center" Foreground="#8b949e"/>
                            <DatePicker x:Name="dpDesdeOp" Width="150"/>
                            <TextBlock Text="Hasta:" VerticalAlignment="Center" Foreground="#8b949e"/>
                            <DatePicker x:Name="dpHastaOp" Width="150"/>
                            <Button Content="Generar" Background="#1f6feb" Foreground="White" Click="BtnGenerarOperaciones_Click"/>
                            <Button Content="Exportar CSV" Background="#21262d" Foreground="#e6edf3" Click="BtnExportarOperaciones_Click"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- DataGrid -->
                    <DataGrid Grid.Row="1" x:Name="dgOperaciones" AutoGenerateColumns="False"
                              Background="#0d1117" RowBackground="#0d1117" Foreground="#e6edf3"
                              BorderThickness="1" BorderBrush="#30363d" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                            <DataGridTextColumn Header="FECHA" Binding="{Binding Fecha, StringFormat='{}{0:dd/MM/yyyy HH:mm}'}" Width="150"/>
                            <DataGridTextColumn Header="TIPO" Binding="{Binding TipoOperacion}" Width="120"/>
                            <DataGridTextColumn Header="MONTO ORIGEN" Binding="{Binding MontoTotalOrigen, StringFormat='{}{0:N2}'}" Width="130"/>
                            <DataGridTextColumn Header="MONTO DESTINO" Binding="{Binding MontoTotalDestino, StringFormat='{}{0:N2}'}" Width="130"/>
                            <DataGridTextColumn Header="COTIZACIÓN" Binding="{Binding CotizacionAplicada, StringFormat='{}{0:N5}'}" Width="120"/>
                            <DataGridTextColumn Header="OBSERVACIONES" Binding="{Binding Observaciones}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <!-- Tab: Saldos por Cuenta -->
            <TabItem Header="Saldos por Cuenta">
                <Grid Margin="10" RowDefinitions="Auto, *">
                    <!-- Filtros -->
                    <Border Grid.Row="0" Background="#0d1117" CornerRadius="6" Padding="15" Margin="0,10,0,15">
                        <StackPanel Orientation="Horizontal" Spacing="15">
                            <TextBlock Text="Tipo:" VerticalAlignment="Center" Foreground="#8b949e"/>
                            <ComboBox x:Name="cmbTipoSaldos" Width="150" SelectedIndex="0">
                                <ComboBoxItem>Todos</ComboBoxItem>
                                <ComboBoxItem>Caja</ComboBoxItem>
                                <ComboBoxItem>Banco</ComboBoxItem>
                                <ComboBoxItem>Cliente</ComboBoxItem>
                            </ComboBox>
                            <Button Content="Generar" Background="#1f6feb" Foreground="White" Click="BtnGenerarSaldos_Click"/>
                            <Button Content="Exportar CSV" Background="#21262d" Foreground="#e6edf3" Click="BtnExportarSaldos_Click"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- DataGrid -->
                    <DataGrid Grid.Row="1" x:Name="dgSaldos" AutoGenerateColumns="False"
                              Background="#0d1117" RowBackground="#0d1117" Foreground="#e6edf3"
                              BorderThickness="1" BorderBrush="#30363d" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                            <DataGridTextColumn Header="CUENTA" Binding="{Binding Nombre}" Width="*"/>
                            <DataGridTextColumn Header="TIPO" Binding="{Binding Tipo}" Width="100"/>
                            <DataGridTextColumn Header="MONEDA" Binding="{Binding Moneda}" Width="100"/>
                            <DataGridTextColumn Header="SALDO" Binding="{Binding Saldo, StringFormat='{}{0:N2}'}" Width="150"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Footer -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Cerrar" Background="Transparent" BorderBrush="#30363d" BorderThickness="1" Foreground="#e6edf3" Width="100" Height="36" Click="BtnCerrar_Click"/>
        </StackPanel>
    </Grid>
</Window>
