<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:icon="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        xmlns:converters="clr-namespace:SistemaCambio.Views.Converters"
        x:Class="SistemaCambio.Views.DetalleCuentaWindow"
        x:CompileBindings="False"
        Title="Detalle de Cuenta"
        Width="1100" MinWidth="960" Height="750" MinHeight="600"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        Background="{DynamicResource AppBackgroundBrush}">

    <Window.Resources>
        <converters:HexColorToBrushConverter x:Key="HexColorToBrushConverter"/>
        <converters:GananciaSignoToBrushConverter x:Key="GananciaSignoToBrushConverter"/>
    </Window.Resources>

    <Grid RowDefinitions="Auto, Auto, *, Auto" Margin="20">
        
        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource CardBackgroundBrush}" 
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" 
                CornerRadius="8" Padding="16,12" Margin="0,0,0,20">
            <Grid ColumnDefinitions="Auto, *">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <icon:MaterialIcon Kind="Bank" Foreground="{DynamicResource AccentBrush}" Width="28" Height="28"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding NombreCuenta}" FontWeight="Bold" FontSize="18"
                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                        <TextBlock Text="{Binding TipoCuenta}" FontWeight="Medium" FontSize="12"
                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Saldos por Moneda -->
        <Border Grid.Row="1" Background="{DynamicResource CardBackgroundBrush}" 
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" 
                CornerRadius="8" Padding="16" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Saldos Actuales" FontWeight="SemiBold" FontSize="14" 
                           Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12"/>
                <ItemsControl ItemsSource="{Binding Saldos}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource AppBackgroundBrush}"
                                    BorderBrush="{Binding ColorHex, Converter={StaticResource HexColorToBrushConverter}}" BorderThickness="1"
                                    CornerRadius="6" Padding="16,12" Margin="0,0,12,12" MinWidth="180">
                                <StackPanel>
                                    <TextBlock Text="{Binding Moneda}" FontWeight="SemiBold" FontSize="12"
                                               Foreground="{Binding ColorHex, Converter={StaticResource HexColorToBrushConverter}}"/>
                                    <TextBlock Text="{Binding SaldoFormatted}" FontWeight="Bold" FontSize="20"
                                               Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- Últimos Movimientos -->
        <Border Grid.Row="2" Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                CornerRadius="8" Padding="16">
            <Grid RowDefinitions="Auto, Auto, *">
                <TextBlock Grid.Row="0" Text="Movimientos" FontWeight="SemiBold" FontSize="14"
                           Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12"/>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="10" Margin="0,0,0,12">
                    <TextBlock Text="Desde" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <DatePicker SelectedDate="{Binding FechaDesde}"/>
                    <TextBlock Text="Hasta" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <DatePicker SelectedDate="{Binding FechaHasta}"/>
                    <Button Content="Filtrar" Classes="Primary" Command="{Binding FiltrarCommand}"
                            HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
                    <Button Content="Limpiar Filtro" Classes="Secondary" Command="{Binding LimpiarFiltroCommand}"
                            HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
                </StackPanel>

                <DataGrid Grid.Row="2" ItemsSource="{Binding Movimientos}" AutoGenerateColumns="False"
                          BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="{DynamicResource BorderBrush}"
                          HeadersVisibility="Column"
                          IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="FECHA" Binding="{Binding Fecha, StringFormat='{}{0:dd/MM/yyyy HH:mm}'}" Width="158"/>
                        <DataGridTextColumn Header="CÓDIGO OPERACIÓN" Binding="{Binding CodigoOperacion}" Width="Auto" MinWidth="150"/>
                        <DataGridTextColumn Header="MONEDA" Binding="{Binding Moneda}" Width="Auto" MinWidth="80"/>
                        <DataGridTemplateColumn Header="MONTO" Width="*" MinWidth="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding MontoFormatted}"
                                               Foreground="{Binding Monto, Converter={StaticResource GananciaSignoToBrushConverter}}"
                                               FontWeight="Bold"
                                               VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
                <TextBlock Grid.Row="2" Text="No hay movimientos registrados en esta cuenta."
                           Foreground="{DynamicResource SecondaryTextBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" IsVisible="{Binding SinMovimientos}"/>
            </Grid>
        </Border>

        <!-- Footer -->
        <Grid Grid.Row="3" Margin="0,20,0,0" ColumnDefinitions="Auto, Auto, *">
            <Button Grid.Column="0" Content="Exportar PDF" Classes="Secondary" Height="40"
                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                    Margin="0,0,10,0" Click="BtnExportarPdf_Click"/>
            <Button Grid.Column="1" Content="Exportar Excel" Classes="Secondary" Height="40"
                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                    Click="BtnExportarCsv_Click"/>
            <Button Grid.Column="2" HorizontalAlignment="Right" Content="Cerrar" Classes="Secondary" Width="100" Height="40"
                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                    Click="BtnCerrar_Click"/>
        </Grid>

    </Grid>
</Window>
