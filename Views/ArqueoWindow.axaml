<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:icon="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        x:Class="SistemaCambio.Views.ArqueoWindow"
        x:CompileBindings="False"
        Title="Arqueo - Caja: TODAS"
        Width="850" Height="600"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        Background="{DynamicResource AppBackgroundBrush}">

    <Grid RowDefinitions="Auto, Auto, *, Auto" Margin="16">
        
        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource CardBackgroundBrush}" 
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" 
                CornerRadius="8" Padding="14,10" Margin="0,0,0,16">
            <Grid ColumnDefinitions="Auto, *, Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10">
                    <icon:MaterialIcon Kind="Calculator" Foreground="{DynamicResource AccentBrush}" Width="22" Height="22"/>
                    <TextBlock x:Name="txtTitulo" Text="Arqueo - Caja: TODAS" FontWeight="SemiBold" FontSize="14" 
                               Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Grid.Column="2" x:Name="txtFecha" Text="" 
                           Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Filter -->
        <Border Grid.Row="1" Background="{DynamicResource CardBackgroundBrush}" 
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" 
                CornerRadius="8" Padding="16" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal" Spacing="15">
                <TextBlock Text="Filtrar por Caja:" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}"/>
                <ComboBox x:Name="cmbCaja" Width="250" SelectedIndex="0" SelectionChanged="CmbCaja_SelectionChanged">
                    <ComboBoxItem Content="TODAS" Tag="0"/>
                </ComboBox>
                <Button Content="Refrescar" Background="{DynamicResource HoverBackgroundBrush}" 
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6"
                        Foreground="{DynamicResource PrimaryTextBrush}" Click="BtnRefrescar_Click"/>
            </StackPanel>
        </Border>

        <!-- DataGrid -->
        <DataGrid Grid.Row="2" x:Name="dgArqueo" AutoGenerateColumns="False" 
                  BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}"
                  GridLinesVisibility="Horizontal"
                  HorizontalGridLinesBrush="{DynamicResource BorderBrush}"
                  HeadersVisibility="Column"
                  CanUserResizeColumns="True">
            
            <DataGrid.Columns>
                <DataGridTextColumn Header="CÓDIGO" Binding="{Binding Codigo}" Width="100" IsReadOnly="True"/>
                <DataGridTextColumn Header="MONEDA" Binding="{Binding Moneda}" Width="180" IsReadOnly="True"/>
                <DataGridTextColumn Header="SALDO SISTEMA" Binding="{Binding SaldoSistema, StringFormat='{}{0:N2}'}" Width="150" IsReadOnly="True"/>
                <DataGridTextColumn Header="ARQUEO" Binding="{Binding SaldoArqueo, StringFormat='{}{0:N2}'}" Width="150"/>
                <DataGridTextColumn Header="DIFERENCIA" Binding="{Binding Diferencia, StringFormat='{}{0:N2}'}" Width="150" IsReadOnly="True"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Footer -->
        <Grid Grid.Row="3" ColumnDefinitions="*, Auto" Margin="0,16,0,0">
            <Border Grid.Column="0" Background="{DynamicResource CardBackgroundBrush}" 
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" 
                    CornerRadius="6" Padding="16,8">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBlock Text="Total Diferencias:" Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <TextBlock x:Name="txtTotalDiferencia" Text="0.00" FontWeight="Bold" 
                               Foreground="{DynamicResource WarningBrush}"/>
                </StackPanel>
            </Border>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
                <Button Content="Aceptar" Background="{DynamicResource AccentBrush}" Foreground="White" 
                        Width="110" Height="36" HorizontalContentAlignment="Center" CornerRadius="8" 
                        Cursor="Hand" Click="BtnAceptar_Click"/>
                <Button Content="Salir" Classes="Secondary" Width="110" Height="36" 
                        HorizontalContentAlignment="Center" Click="BtnSalir_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
