<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SistemaCambio.Views.Controls"
        xmlns:helpers="clr-namespace:SistemaCambio.Views.Helpers"
        x:Class="SistemaCambio.Views.ArqueoWindow"
        x:CompileBindings="False"
        Title="Arqueo - Caja: TODAS"
        Width="720"
        MinHeight="220" MaxHeight="600"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        Background="{DynamicResource AppBackgroundBrush}">

    <Grid RowDefinitions="*, Auto" Margin="10">

        <DataGrid Grid.Row="0" x:Name="dgArqueo"
                  AutoGenerateColumns="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="All"
                  HorizontalGridLinesBrush="{DynamicResource BorderBrush}"
                  VerticalGridLinesBrush="{DynamicResource BorderBrush}"
                  BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}"
                  RowHeight="26"
                  CanUserReorderColumns="False"
                  CanUserSortColumns="False"
                  SelectionMode="Single">

            <DataGrid.Columns>

                <DataGridTemplateColumn Header="Código" Width="70" IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding CodigoMoneda}"
                                       VerticalAlignment="Center" Margin="8,0"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="Moneda" Width="2*" IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding NombreMoneda}"
                                       VerticalAlignment="Center" Margin="8,0"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="Saldo" Width="*" IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding SaldoSistema, StringFormat='{}{0:N2}'}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Right"
                                       Margin="8,0"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="Arqueo" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding ArqueoFisico, StringFormat='{}{0:N2}'}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Right"
                                       Margin="8,0"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding ArqueoFisico, Mode=TwoWay}"
                                     HorizontalContentAlignment="Right"
                                     Padding="6,2"
                                     helpers:NumericInput.Enabled="True"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>

                <DataGridTemplateColumn Header="Diferencia" Width="*" IsReadOnly="True">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Diferencia, StringFormat='{}{0:N2}'}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Right"
                                       Margin="8,0"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="10"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button HotKey="Alt+A" Classes="Primary"
                    Width="110" Height="36"
                    IsDefault="True"
                    Click="BtnAceptar_Click">
                <AccessText Text="_Aceptar"/>
            </Button>
            <Button HotKey="Alt+S" Classes="Secondary"
                    Width="110" Height="36"
                    Click="BtnSalir_Click">
                <AccessText Text="_Salir"/>
            </Button>
        </StackPanel>

        <controls:NotificationPanel x:Name="notificationPanel"
                                    Grid.RowSpan="2"
                                    VerticalAlignment="Top"
                                    HorizontalAlignment="Right"
                                    ZIndex="100"/>
    </Grid>
</Window>
