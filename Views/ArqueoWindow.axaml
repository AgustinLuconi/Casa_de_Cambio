<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:icon="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        x:Class="SistemaCambio.Views.ArqueoWindow"
        x:CompileBindings="False"
        Title="Arqueo - Caja: TODAS"
        Width="850" Height="600"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        Background="#161b22">

    <Grid RowDefinitions="Auto, Auto, *, Auto" Margin="15">
        
        <!-- Header -->
        <Border Grid.Row="0" Background="#21262d" BorderBrush="#30363d" BorderThickness="1" CornerRadius="6" Padding="12,8" Margin="0,0,0,15">
            <Grid ColumnDefinitions="Auto, *, Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10">
                    <icon:MaterialIcon Kind="Calculator" Foreground="#f0883e" Width="24" Height="24"/>
                    <TextBlock x:Name="txtTitulo" Text="Arqueo - Caja: TODAS" FontWeight="Bold" FontSize="14" Foreground="#e6edf3" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Grid.Column="2" x:Name="txtFecha" Text="" Foreground="#8b949e" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Filtro de Caja -->
        <Border Grid.Row="1" Background="#0d1117" CornerRadius="6" Padding="15" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal" Spacing="15">
                <TextBlock Text="Filtrar por Caja:" VerticalAlignment="Center" Foreground="#8b949e"/>
                <ComboBox x:Name="cmbCaja" Width="250" SelectedIndex="0" SelectionChanged="CmbCaja_SelectionChanged">
                    <ComboBoxItem Content="TODAS" Tag="0"/>
                </ComboBox>
                <Button Content="Refrescar" Background="#21262d" Foreground="#e6edf3" Click="BtnRefrescar_Click">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <icon:MaterialIcon Kind="Refresh" Width="16" Height="16"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- DataGrid -->
        <DataGrid Grid.Row="2" x:Name="dgArqueo" AutoGenerateColumns="False" 
                  Background="#0d1117" 
                  RowBackground="#0d1117" 
                  Foreground="#e6edf3"
                  BorderThickness="1" 
                  BorderBrush="#30363d" 
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  CornerRadius="6"
                  CanUserResizeColumns="True">
            
            <DataGrid.Styles>
               <Style Selector="DataGridColumnHeader">
                    <Setter Property="Background" Value="#161b22"/>
                    <Setter Property="Foreground" Value="#8b949e"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="Padding" Value="12,10"/>
                    <Setter Property="FontSize" Value="12"/>
               </Style>
            </DataGrid.Styles>

            <DataGrid.Columns>
                <DataGridTextColumn Header="CÓDIGO" Binding="{Binding Codigo}" Width="100" IsReadOnly="True" Foreground="#8b949e"/>
                <DataGridTextColumn Header="MONEDA" Binding="{Binding Moneda}" Width="180" IsReadOnly="True"/>
                <DataGridTextColumn Header="SALDO SISTEMA" Binding="{Binding SaldoSistema, StringFormat='{}{0:N2}'}" Width="150" IsReadOnly="True" Foreground="#58a6ff"/>
                <DataGridTextColumn Header="ARQUEO" Binding="{Binding SaldoArqueo, StringFormat='{}{0:N2}'}" Width="150"/>
                <DataGridTextColumn Header="DIFERENCIA" Binding="{Binding Diferencia, StringFormat='{}{0:N2}'}" Width="150" IsReadOnly="True"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Footer -->
        <Grid Grid.Row="3" ColumnDefinitions="*, Auto" Margin="0,15,0,0">
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="20">
                <Border Background="#21262d" CornerRadius="4" Padding="15,8">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock Text="Total Diferencias:" Foreground="#8b949e"/>
                        <TextBlock x:Name="txtTotalDiferencia" Text="0.00" FontWeight="Bold" Foreground="#f0883e"/>
                    </StackPanel>
                </Border>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
                <Button Content="Aceptar" Background="#238636" Foreground="White" Width="110" Height="36" HorizontalContentAlignment="Center" Click="BtnAceptar_Click"/>
                <Button Content="Salir" Background="Transparent" BorderBrush="#30363d" BorderThickness="1" Foreground="#e6edf3" Width="110" Height="36" HorizontalContentAlignment="Center" Click="BtnSalir_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
