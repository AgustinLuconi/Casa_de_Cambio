<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:icon="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        xmlns:controls="clr-namespace:SistemaCambio.Views.Controls"
        x:Class="SistemaCambio.Views.CompraWindow"
        Title="Compra de Divisa"
        Width="800" Height="500"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="{DynamicResource AppBackgroundBrush}">

    <Grid RowDefinitions="Auto, *" Margin="16">
        
        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource CardBackgroundBrush}" 
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" 
                CornerRadius="8" Padding="14,10" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <icon:MaterialIcon Kind="CartArrowDown" Foreground="{DynamicResource SuccessBrush}" Width="22" Height="22"/>
                <TextBlock Text="Registrar Compra (Ingreso de Divisa)" FontWeight="SemiBold" FontSize="14" 
                           Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" ColumnDefinitions="1.2*, 1.5*">
            <!-- Left Column: Fields -->
            <StackPanel Grid.Column="0" Spacing="10" Margin="0,0,20,0">
                
                <Grid ColumnDefinitions="120, *">
                    <TextBlock Text="Monto Divisa" VerticalAlignment="Center"
                               Foreground="{DynamicResource PrimaryTextBrush}" FontWeight="SemiBold"/>
                    <TextBox x:Name="txtMontoDestino" Grid.Column="1" Text="0.00" TextAlignment="Right" 
                             FontWeight="Bold" KeyUp="Recalcular_KeyUp" GotFocus="TextBox_GotFocus"/>
                </Grid>

                <Grid ColumnDefinitions="120, *">
                    <TextBlock Text="Cliente paga (ARS)" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <TextBox x:Name="txtPagaCon" Grid.Column="1" Text="0.00" TextAlignment="Right" 
                             KeyUp="Recalcular_KeyUp" GotFocus="TextBox_GotFocus"/>
                </Grid>

                <Grid ColumnDefinitions="120, *">
                    <TextBlock Text="Vuelto" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <TextBox x:Name="txtVuelto" Grid.Column="1" Text="0.00" TextAlignment="Right"/>
                </Grid>

                <Grid ColumnDefinitions="120, *">
                    <TextBlock Text="Cotización" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <TextBox x:Name="txtCotizacion" Grid.Column="1" Text="0.00000" TextAlignment="Right" 
                             KeyUp="Recalcular_KeyUp" GotFocus="TextBox_GotFocus"/>
                </Grid>

                <Grid ColumnDefinitions="120, *">
                    <TextBlock Text="Total ARS" VerticalAlignment="Center"
                               Foreground="{DynamicResource PrimaryTextBrush}" FontWeight="SemiBold"/>
                    <TextBox x:Name="txtMontoOrigen" Grid.Column="1" Text="0.00" TextAlignment="Right" 
                             FontWeight="Bold" IsReadOnly="True"/>
                </Grid>

                <Grid ColumnDefinitions="120, *">
                    <TextBlock Text="Observaciones" VerticalAlignment="Top" Margin="0,5,0,0" 
                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <TextBox x:Name="txtObservaciones" Grid.Column="1" Height="60" AcceptsReturn="True"/>
                </Grid>

                <Grid ColumnDefinitions="120, *">
                    <TextBlock Text="Tipo Operación" VerticalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <ComboBox x:Name="cmbTipoOperacion" Grid.Column="1" HorizontalAlignment="Stretch" SelectedIndex="0">
                         <ComboBoxItem>Normal</ComboBoxItem>
                         <ComboBoxItem>Interbancaria</ComboBoxItem>
                    </ComboBox>
                </Grid>

            </StackPanel>

            <!-- Right Column: Accounts -->
            <StackPanel Grid.Column="1" Spacing="16">
                
                <!-- Destination Account (divisa) -->
                <StackPanel Spacing="6">
                    <TextBlock Text="Acreditar divisa en (Destino)" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12"/>
                    <Border Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource SuccessBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="6">
                        <ComboBox x:Name="cmbDestino" HorizontalAlignment="Stretch"
                                  Background="Transparent" BorderThickness="0"/>
                    </Border>
                </StackPanel>

                <!-- Source Account (ARS fija) -->
                <StackPanel Spacing="6">
                    <TextBlock Text="Cuenta ARS (Origen - fija)" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12"/>
                    <Border Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource DangerBrush}"
                            BorderThickness="1" CornerRadius="8" Padding="12,8">
                        <TextBlock x:Name="txtCuentaARSFija" Text="Cargando..."
                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                    </Border>
                </StackPanel>

                <!-- Error Panel -->
                <Border x:Name="borderError" IsVisible="False"
                        Background="#DC262620" BorderBrush="{DynamicResource DangerBrush}"
                        BorderThickness="1" CornerRadius="8" Padding="12,8" Margin="0,10,0,10">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <icon:MaterialIcon Kind="AlertCircle" Foreground="{DynamicResource DangerBrush}"
                                          Width="16" Height="16" VerticalAlignment="Center"/>
                        <TextBlock x:Name="txtErrorServidor" Text="" TextWrapping="Wrap"
                                   Foreground="{DynamicResource DangerBrush}" FontSize="12"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Buttons -->
                <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                    <Button Content="Aceptar" Background="{DynamicResource AccentBrush}" Foreground="White" 
                            Width="110" Height="36" HorizontalContentAlignment="Center" CornerRadius="8" 
                            Cursor="Hand" Click="BotonAceptar_Click"/>
                    <Button Content="Cancelar" Classes="Secondary" Width="110" Height="36" 
                            HorizontalContentAlignment="Center" Click="BotonCancelar_Click"/>
                </StackPanel>

            </StackPanel>
        </Grid>
        <controls:NotificationPanel x:Name="notificationPanel"
                                         Grid.RowSpan="2"
                                         VerticalAlignment="Top"
                                         HorizontalAlignment="Right"
                                         ZIndex="100"/>
    </Grid>
</Window>