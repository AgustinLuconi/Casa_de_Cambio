<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:icon="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        xmlns:controls="clr-namespace:SistemaCambio.Views.Controls"
        xmlns:helpers="clr-namespace:SistemaCambio.Views.Helpers"
        x:Class="SistemaCambio.Views.CompraWindow"
        Title="Compra de Divisa"
        Width="740" Height="470"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="{DynamicResource AppBackgroundBrush}">

    <Grid RowDefinitions="Auto, *, Auto" Margin="16">

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                CornerRadius="8" Padding="14,10" Margin="0,0,0,14">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <icon:MaterialIcon Kind="CartArrowDown" Foreground="{DynamicResource SuccessBrush}" Width="22" Height="22"/>
                <TextBlock Text="Registrar Compra (Ingreso de Divisa)"
                           FontWeight="SemiBold" FontSize="14"
                           Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!--
            Formulario — 4 columnas:
              Col 0 (130): etiquetas izquierda
              Col 1 (160): campos de entrada
              Col 2 (140): etiquetas de cuenta (derecha)
              Col 3  (* ): ComboBoxes de cuenta (derecha)
        -->
        <Grid Grid.Row="1"
              ColumnDefinitions="130, 160, 140, *"
              RowDefinitions="Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto">

            <!-- ── Fila 0: Moneda ── -->
            <TextBlock Grid.Row="0" Grid.Column="0"
                       Text="Moneda" VerticalAlignment="Center"
                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,9"/>
            <!-- Pequeño ComboBox de código + TextBox de nombre (read-only) -->
            <Grid Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="3"
                  ColumnDefinitions="95, *" Margin="0,0,0,9">
                <ComboBox x:Name="cmbMoneda" Grid.Column="0"
                          HorizontalAlignment="Stretch"
                          SelectionChanged="CmbMoneda_SelectionChanged"/>
                <TextBox x:Name="txtMonedaNombre" Grid.Column="1" Margin="8,0,0,0"
                         Foreground="{DynamicResource PrimaryTextBrush}"
                         TextChanged="TxtMoneda_TextChanged"
                         LostFocus="TxtMoneda_LostFocus"/>
            </Grid>

            <!-- ── Fila 1: Mon. Extranjera | Acredita en cuenta (ROJO) ── -->
            <TextBlock Grid.Row="1" Grid.Column="0"
                       Text="Mon. Extranjera" VerticalAlignment="Center"
                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,9"/>
            <TextBox x:Name="txtMonedaExtranjera" Grid.Row="1" Grid.Column="1"
                     Text="0.00" TextAlignment="Right" Margin="0,0,0,9"
                     helpers:NumericInput.Enabled="True"
                     KeyUp="Recalcular_KeyUp" GotFocus="TextBox_GotFocus" LostFocus="TextBox_LostFocus"/>
            <TextBlock Grid.Row="1" Grid.Column="2"
                       Text="Acredita en cuenta" VerticalAlignment="Center"
                       Foreground="{DynamicResource PrimaryTextBrush}"
                       Margin="10,0,8,9"/>
            <AutoCompleteBox x:Name="cmbCuentaAcredita" Grid.Row="1" Grid.Column="3"
                             Classes="cuentaRoja"
                             HorizontalAlignment="Stretch" Margin="0,0,0,9"
                             Watermark="Buscar cuenta..."
                             MaxDropDownHeight="240"/>

            <!-- ── Fila 2: Ingresa ── -->
            <TextBlock Grid.Row="2" Grid.Column="0"
                       Text="Ingresa" VerticalAlignment="Center"
                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,9"/>
            <TextBox x:Name="txtIngresa" Grid.Row="2" Grid.Column="1"
                     Text="0.00" TextAlignment="Right" Margin="0,0,0,9"
                     helpers:NumericInput.Enabled="True"
                     KeyUp="Recalcular_KeyUp" GotFocus="TextBox_GotFocus" LostFocus="TextBox_LostFocus"/>

            <!-- ── Fila 3: Vuelto (solo lectura) ── -->
            <TextBlock Grid.Row="3" Grid.Column="0"
                       Text="Vuelto" VerticalAlignment="Center"
                       Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,9"/>
            <TextBox x:Name="txtVuelto" Grid.Row="3" Grid.Column="1"
                     Text="0.00" TextAlignment="Right" IsReadOnly="True" IsTabStop="False"
                     Margin="0,0,0,9"
                     Background="{DynamicResource SidebarBackgroundBrush}"
                     Foreground="{DynamicResource SecondaryTextBrush}"/>

            <!-- ── Fila 4: Cotización ── -->
            <TextBlock Grid.Row="4" Grid.Column="0"
                       Text="Cotización" VerticalAlignment="Center"
                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,9"/>
            <TextBox x:Name="txtCotizacion" Grid.Row="4" Grid.Column="1"
                     Text="0.00000" TextAlignment="Right" Margin="0,0,0,9"
                     helpers:NumericInput.Enabled="True"
                     KeyUp="Recalcular_KeyUp" GotFocus="TextBox_GotFocus" LostFocus="TextBox_LostFocus"/>

            <!-- ── Fila 5: Pesos (solo lectura) | Debita de cuenta (VERDE) ── -->
            <TextBlock Grid.Row="5" Grid.Column="0"
                       Text="Pesos" VerticalAlignment="Center"
                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,9"/>
            <TextBox x:Name="txtPesos" Grid.Row="5" Grid.Column="1"
                     Text="0.00" TextAlignment="Right" IsReadOnly="True" IsTabStop="False"
                     Margin="0,0,0,9"/>
            <TextBlock Grid.Row="5" Grid.Column="2"
                       Text="Debita de cuenta" VerticalAlignment="Center"
                       Foreground="{DynamicResource PrimaryTextBrush}"
                       Margin="10,0,8,9"/>
            <AutoCompleteBox x:Name="cmbCuentaDebita" Grid.Row="5" Grid.Column="3"
                             Classes="cuentaVerde"
                             HorizontalAlignment="Stretch" Margin="0,0,0,9"
                             Watermark="Buscar cuenta..."
                             MaxDropDownHeight="240"/>

            <!-- ── Fila 6: Observaciones (span columnas de input) ── -->
            <TextBlock Grid.Row="6" Grid.Column="0"
                       Text="Observaciones" VerticalAlignment="Center"
                       Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,9"/>
            <TextBox x:Name="txtObservaciones" Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="3"
                     Height="32" Margin="0,0,0,9"/>

            <!-- ── Fila 7: Tipo operación ── -->
            <TextBlock Grid.Row="7" Grid.Column="0"
                       Text="Tipo operación" VerticalAlignment="Center"
                       Foreground="{DynamicResource SecondaryTextBrush}"/>
            <ComboBox x:Name="cmbTipoOperacion" Grid.Row="7" Grid.Column="1"
                      HorizontalAlignment="Stretch">
                <ComboBoxItem>Normal</ComboBoxItem>
            </ComboBox>

        </Grid>

        <!-- Fila inferior: error + botones -->
        <Grid Grid.Row="2" ColumnDefinitions="*, Auto" Margin="0,12,0,0">

            <Border x:Name="borderError" IsVisible="False"
                    Background="#DC262620" BorderBrush="{DynamicResource DangerBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="12,8">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <icon:MaterialIcon Kind="AlertCircle" Foreground="{DynamicResource DangerBrush}"
                                       Width="16" Height="16" VerticalAlignment="Center"/>
                    <TextBlock x:Name="txtErrorServidor" Text="" TextWrapping="Wrap"
                               Foreground="{DynamicResource DangerBrush}" FontSize="12"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
                <Button x:Name="btnAceptar" Content="Aceptar" Classes="Primary"
                        Width="110" Height="36"
                        Click="BotonAceptar_Click"/>
                <Button Content="Cancelar" Classes="Secondary"
                        Width="110" Height="36"
                        Click="BotonCancelar_Click"/>
            </StackPanel>

        </Grid>

        <controls:NotificationPanel x:Name="notificationPanel"
                                    Grid.RowSpan="3"
                                    VerticalAlignment="Top"
                                    HorizontalAlignment="Right"
                                    ZIndex="100"/>
    </Grid>
</Window>
