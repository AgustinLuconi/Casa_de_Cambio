<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:icon="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        xmlns:vm="using:SistemaCambio.ViewModels"
        x:DataType="vm:RecuperarPasswordViewModel"
        x:Class="SistemaCambio.Views.RecuperarPasswordWindow"
        Title="Casa de Cambio - Recuperar Contrase&#241;a"
        Width="480" Height="620"
        WindowStartupLocation="CenterScreen"
        CanResize="False"
        Background="#101c22">

    <Grid>
        <Ellipse Width="350" Height="350" Fill="#13a4ec" Opacity="0.06"
                 HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-80,-60,0,0">
            <Ellipse.Effect><BlurEffect Radius="80"/></Ellipse.Effect>
        </Ellipse>
        <Ellipse Width="280" Height="280" Fill="#0d79b3" Opacity="0.07"
                 HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-60,-60">
            <Ellipse.Effect><BlurEffect Radius="80"/></Ellipse.Effect>
        </Ellipse>

        <!-- ══════════ PANEL 1 — Ingreso de email ══════════ -->
        <Border IsVisible="{Binding EsPaso1}"
                Background="#14232b" CornerRadius="16"
                BorderBrush="#1e3441" BorderThickness="1"
                BoxShadow="0 25 60 0 #99000000"
                Width="400"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Padding="32">
            <StackPanel Spacing="16">

                <Border Width="52" Height="52" CornerRadius="14"
                        Background="#1a3a50" HorizontalAlignment="Center">
                    <icon:MaterialIcon Kind="LockOutline" Width="28" Height="28"
                                       Foreground="#13a4ec"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <TextBlock Text="Recuperar Contrase&#241;a"
                           FontSize="28" FontWeight="Bold" Foreground="White"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Ingres&#225; tu email y te enviaremos instrucciones"
                           FontSize="14" Foreground="#94a3b8"
                           HorizontalAlignment="Center" Margin="0,-8,0,4"
                           TextWrapping="Wrap" TextAlignment="Center"/>

                <!-- Campo: Email -->
                <StackPanel Spacing="6">
                    <TextBlock Text="Email" Foreground="#CBD5E1" FontSize="13"/>
                    <Grid>
                        <TextBox Text="{Binding Email}"
                                 Padding="44,12,12,12" Height="44"
                                 Background="#0c151a" Foreground="White"
                                 BorderBrush="#233c4a" BorderThickness="1"
                                 CornerRadius="10"
                                 Watermark="tu@email.com"/>
                        <icon:MaterialIcon Kind="EmailOutline"
                                           Width="18" Height="18"
                                           VerticalAlignment="Center" HorizontalAlignment="Left"
                                           Margin="14,0,0,0" Foreground="#64748B"
                                           IsHitTestVisible="False"/>
                    </Grid>
                </StackPanel>

                <!-- Mensaje de error -->
                <TextBlock Text="{Binding ErrorMessage}"
                           IsVisible="{Binding TieneError}"
                           Foreground="#ef4444" FontSize="12"
                           TextWrapping="Wrap" Margin="0,-4,0,0"/>

                <!-- Botón principal -->
                <Button Command="{Binding EnviarEmailCommand}"
                        IsEnabled="{Binding !IsLoading}"
                        Height="44" CornerRadius="10"
                        Background="#13a4ec" Foreground="White"
                        FontWeight="SemiBold" FontSize="14"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Margin="0,4,0,0">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock IsVisible="{Binding !IsLoading}"
                                   Text="Enviar instrucciones" VerticalAlignment="Center"/>
                        <TextBlock IsVisible="{Binding IsLoading}"
                                   Text="Enviando..." VerticalAlignment="Center"/>
                        <icon:MaterialIcon Kind="ArrowRight" Width="18" Height="18"
                                           IsVisible="{Binding !IsLoading}"
                                           VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Link volver al login -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="4">
                    <TextBlock Text="&#191;Record&#225;ste tu contrase&#241;a?" Foreground="#94A3B8" FontSize="12"
                               VerticalAlignment="Center"/>
                    <Button Content="Inici&#225; sesi&#243;n"
                            Command="{Binding VolverAlLoginCommand}"
                            Background="Transparent" BorderThickness="0"
                            Foreground="#13a4ec" FontSize="12" Padding="0"
                            Cursor="Hand"/>
                </StackPanel>

            </StackPanel>
        </Border>

        <!-- ══════════ PANEL 2 — Confirmación ══════════ -->
        <Border IsVisible="{Binding EsPaso2}"
                Background="#14232b" CornerRadius="16"
                BorderBrush="#1e3441" BorderThickness="1"
                BoxShadow="0 25 60 0 #99000000"
                Width="400"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Padding="40">
            <StackPanel Spacing="20" HorizontalAlignment="Center">

                <Border Width="72" Height="72" CornerRadius="36"
                        Background="#0d2e1f" HorizontalAlignment="Center">
                    <icon:MaterialIcon Kind="EmailOutline" Width="40" Height="40"
                                       Foreground="#13a4ec"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <TextBlock Text="Revis&#225; tu email"
                           FontSize="24" FontWeight="Bold" Foreground="White"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="Si el email existe en nuestro sistema, recibir&#225;s un c&#243;digo de 8 caracteres por email."
                           FontSize="14" Foreground="#94a3b8"
                           TextWrapping="Wrap" TextAlignment="Center"/>

                <TextBlock Text="El c&#243;digo expira en 1 hora."
                           FontSize="12" Foreground="#64748b"
                           HorizontalAlignment="Center"/>

                <Button Content="Ya tengo el c&#243;digo &#8594;"
                        Command="{Binding IrAlPaso3Command}"
                        Height="44" CornerRadius="10"
                        Background="Transparent"
                        BorderBrush="#13a4ec" BorderThickness="1"
                        Foreground="#13a4ec"
                        FontWeight="SemiBold" FontSize="14"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Margin="0,8,0,0"/>

                <Button Content="Volver al Login"
                        Command="{Binding VolverAlLoginCommand}"
                        Height="44" CornerRadius="10"
                        Background="#13a4ec" Foreground="White"
                        FontWeight="SemiBold" FontSize="14"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Margin="0,4,0,0"/>

            </StackPanel>
        </Border>

        <!-- ══════════ PANEL 3 — Ingresar código ══════════ -->
        <Border IsVisible="{Binding EsPaso3}"
                Background="#14232b" CornerRadius="16"
                BorderBrush="#1e3441" BorderThickness="1"
                BoxShadow="0 25 60 0 #99000000"
                Width="400"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Padding="32">
            <StackPanel Spacing="14">

                <Border Width="52" Height="52" CornerRadius="14"
                        Background="#1a3a50" HorizontalAlignment="Center">
                    <icon:MaterialIcon Kind="LockOutline" Width="28" Height="28"
                                       Foreground="#13a4ec"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <TextBlock Text="Ingres&#225; el c&#243;digo"
                           FontSize="24" FontWeight="Bold" Foreground="White"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Copi&#225; el c&#243;digo de 8 caracteres que recibiste por email"
                           FontSize="13" Foreground="#94a3b8"
                           HorizontalAlignment="Center" Margin="0,-6,0,4"
                           TextWrapping="Wrap" TextAlignment="Center"/>

                <!-- Campo: Código -->
                <StackPanel Spacing="6">
                    <TextBlock Text="C&#243;digo de recuperaci&#243;n" Foreground="#CBD5E1" FontSize="13"/>
                    <TextBox Text="{Binding Codigo}"
                             Padding="12,12" Height="44"
                             Background="#0c151a" Foreground="White"
                             BorderBrush="#233c4a" BorderThickness="1"
                             CornerRadius="10"
                             Watermark="Ej: K7MN3QPX"
                             FontFamily="Consolas,Monospace"/>
                </StackPanel>

                <!-- Campo: Nueva contraseña -->
                <StackPanel Spacing="6">
                    <TextBlock Text="Nueva contrase&#241;a" Foreground="#CBD5E1" FontSize="13"/>
                    <TextBox Text="{Binding NuevaPassword}"
                             PasswordChar="&#9679;"
                             Padding="12,12" Height="44"
                             Background="#0c151a" Foreground="White"
                             BorderBrush="#233c4a" BorderThickness="1"
                             CornerRadius="10"
                             Watermark="M&#237;nimo 8 caracteres"/>
                </StackPanel>

                <!-- Campo: Confirmar contraseña -->
                <StackPanel Spacing="6">
                    <TextBlock Text="Confirm&#225; la contrase&#241;a" Foreground="#CBD5E1" FontSize="13"/>
                    <TextBox Text="{Binding ConfirmarPassword}"
                             PasswordChar="&#9679;"
                             Padding="12,12" Height="44"
                             Background="#0c151a" Foreground="White"
                             BorderBrush="#233c4a" BorderThickness="1"
                             CornerRadius="10"
                             Watermark="Repet&#237; la nueva contrase&#241;a"/>
                </StackPanel>

                <!-- Mensaje de error -->
                <TextBlock Text="{Binding ErrorMessage}"
                           IsVisible="{Binding TieneError}"
                           Foreground="#ef4444" FontSize="12"
                           TextWrapping="Wrap" Margin="0,-4,0,0"/>

                <!-- Botón principal -->
                <Button Command="{Binding ResetearPasswordCommand}"
                        IsEnabled="{Binding !IsLoading}"
                        Height="44" CornerRadius="10"
                        Background="#13a4ec" Foreground="White"
                        FontWeight="SemiBold" FontSize="14"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Margin="0,4,0,0">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock IsVisible="{Binding !IsLoading}"
                                   Text="Cambiar contrase&#241;a" VerticalAlignment="Center"/>
                        <TextBlock IsVisible="{Binding IsLoading}"
                                   Text="Procesando..." VerticalAlignment="Center"/>
                        <icon:MaterialIcon Kind="ArrowRight" Width="18" Height="18"
                                           IsVisible="{Binding !IsLoading}"
                                           VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Link volver -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="4">
                    <TextBlock Text="&#191;No recibiste el c&#243;digo?" Foreground="#94A3B8" FontSize="12"
                               VerticalAlignment="Center"/>
                    <Button Content="Volver"
                            Command="{Binding VolverAlLoginCommand}"
                            Background="Transparent" BorderThickness="0"
                            Foreground="#13a4ec" FontSize="12" Padding="0"
                            Cursor="Hand"/>
                </StackPanel>

            </StackPanel>
        </Border>

        <!-- ══════════ PANEL 4 — Éxito final ══════════ -->
        <Border IsVisible="{Binding EsPaso4}"
                Background="#14232b" CornerRadius="16"
                BorderBrush="#1e3441" BorderThickness="1"
                BoxShadow="0 25 60 0 #99000000"
                Width="400"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Padding="40">
            <StackPanel Spacing="20" HorizontalAlignment="Center">

                <Border Width="72" Height="72" CornerRadius="36"
                        Background="#0d2e1f" HorizontalAlignment="Center">
                    <icon:MaterialIcon Kind="CheckCircleOutline" Width="40" Height="40"
                                       Foreground="#13a4ec"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <TextBlock Text="&#161;Contrase&#241;a actualizada!"
                           FontSize="24" FontWeight="Bold" Foreground="White"
                           HorizontalAlignment="Center"/>

                <TextBlock Text="Ya pod&#233;s iniciar sesi&#243;n con tu nueva contrase&#241;a."
                           FontSize="14" Foreground="#94a3b8"
                           TextWrapping="Wrap" TextAlignment="Center"/>

                <Button Content="Ir al Login"
                        Command="{Binding VolverAlLoginCommand}"
                        Height="44" CornerRadius="10"
                        Background="#13a4ec" Foreground="White"
                        FontWeight="SemiBold" FontSize="14"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Margin="0,8,0,0"/>

            </StackPanel>
        </Border>
    </Grid>
</Window>
